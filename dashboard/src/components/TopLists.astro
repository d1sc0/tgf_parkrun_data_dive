---
import { runQuery } from '../lib/bigquery';
import { getCached, setCached } from '../lib/cache';

/**
 * Top Lists Component (SSR Version)
 * Fetches 6 distinct "Top 20" datasets from BigQuery.
 */

const projectId = import.meta.env.GCP_PROJECT_ID;
const viewsDatasetId =
  import.meta.env.BIGQUERY_VIEWS_DATASET_ID ||
  import.meta.env.BIGQUERY_DATASET_ID ||
  'parkrun_data';

const query = `
  SELECT *
  FROM \`${projectId}.${viewsDatasetId}._27_dashboard_top_lists\`
`;

let rows: any[] = [];
try {
  const cacheKey = 'topLists_global';
  const cachedRows = getCached<any[]>(cacheKey);
  
  if (cachedRows) {
    rows = cachedRows;
  } else {
    rows = await runQuery(query);
    setCached(cacheKey, rows, 360); // Cache for 6 hours
  }
} catch (error) {
  console.error('Failed to fetch top lists:', error);
}

const queryKeys = [
  'athletes',
  'athletes_male',
  'athletes_female',
  'volunteers',
  'events',
  'clubs',
];
const topLists = rows[0] || {};
const datasets = queryKeys.reduce(
  (acc, key) => {
    acc[key] = topLists[key] || [];
    return acc;
  },
  {} as Record<string, any[]>,
);

const listMeta = [
  {
    key: 'volunteers',
    title: 'Top 20 Volunteers',
    entity: 'Volunteer',
    header: 'TGF Vol Count', // Corrected header
    format: 'num',
    extra_cols: [ // Added format for extra_cols
      { header: 'Runs', key: 'run_count', format: 'num_or_dash' },
      { header: 'Fastest', key: 'fastest_time', format: 'time_string' },
    ],
  },
  {
    key: 'events',
    title: 'Top 20 Attended Events',
    entity: 'Event Date',
    header: 'Finishers',
    format: 'num', // Added format for main value
    extra_cols: [
      { header: 'Run ID', key: 'run_id', format: 'num' },
      { header: 'Fastest', key: 'fastest_time', format: 'time_string' },
      { header: 'Mean', key: 'mean_time', format: 'time_string' },
      { header: 'Slowest', key: 'slowest_time', format: 'time_string' },
    ],
  },
  {
    key: 'athletes',
    title: 'Top 20 Attendees (ALL)',
    entity: 'Athlete',
    header: 'Runs',
    format: 'num', // Added format for main value
    extra_cols: [ // Added format for extra_cols
      { header: 'Fastest', key: 'fastest_time', format: 'time_string' },
      { header: 'Date', key: 'fastest_date', format: 'date_string' },
      { header: 'Vol', key: 'vol_count', format: 'num' },
    ],
  },
  {
    key: 'athletes_male',
    title: 'Top 20 Attendees (Male)',
    entity: 'Athlete',
    header: 'Runs',
    format: 'num', // Added format for main value
    extra_cols: [ // Added format for extra_cols
      { header: 'Fastest', key: 'fastest_time', format: 'time_string' },
      { header: 'Date', key: 'fastest_date', format: 'date_string' },
      { header: 'Vol', key: 'vol_count', format: 'num' },
    ],
  },
  {
    key: 'athletes_female',
    title: 'Top 20 Attendees (Female)',
    entity: 'Athlete',
    header: 'Runs',
    format: 'num', // Added format for main value
    extra_cols: [ // Added format for extra_cols
      { header: 'Fastest', key: 'fastest_time', format: 'time_string' },
      { header: 'Date', key: 'fastest_date', format: 'date_string' },
      { header: 'Vol', key: 'vol_count', format: 'num' },
    ],
  },
  {
    key: 'clubs',
    title: 'Top 20 Clubs represented',
    entity: 'Running Club',
    header: 'Appearances',
    format: 'num',
    extra_cols: [
      { header: 'Fastest Male', key: 'fastest_male', format: 'athlete_time_pair' },
      { header: 'Fastest Female', key: 'fastest_female', format: 'athlete_time_pair' },
    ],
  },
];

function formatValue(value: any, formatType: string, row: any, colKey: string): string {
  // Return '-' for null, undefined, empty string, or "00:00" for time strings
  if (value === null || value === undefined || value === '' || (formatType === 'time_string' && value === '00:00')) {
    return '-';
  }
  
  switch (formatType) {
    case 'date_string': {
      const parts = String(value).split('-');
      if (parts.length === 3) {
        const dmy = `${parts[2]}-${parts[1]}-${parts[0]}`;
        if (colKey === 'fastest_date' || (colKey === 'label' && row.run_id)) {
          const rid = row.fastest_run_id || row.run_id;
          return rid ? `${dmy} (#${rid})` : dmy;
        }
        return dmy;
      }
      return value;
    }
    case 'time_string':
      return value; // SQL already formats it, so just return
    case 'num':
      return Number(value).toLocaleString();
    case 'num_or_dash':
      // Display 0 as 0, only dash for truly null/undefined/empty/non-finite values
      return Number.isFinite(Number(value)) && Number(value) >= 0 ? Number(value).toLocaleString() : '-';
    default:
      return String(value);
  }
}
---

<div class="top-lists-wrapper">
  <div class="jump-menu" id="top">
    <p class="menu-label">Jump to:</p>
    <div class="menu-links">
      {listMeta.map(meta => <a href={`#${meta.key}`}>{meta.title}</a>)}
    </div>
  </div>

  {
    listMeta.map(meta => (
      <div class="table-card" id={meta.key}>
        <div class="table-header-box">
          <h3 class="card-title">{meta.title}</h3>
        </div>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th style="width: 60px">Rank</th>
                <th>{meta.entity}</th>
                <th>{meta.header}</th>
                {meta.extra_cols?.map(col => (
                  <th>{col.header}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {datasets[meta.key]?.map((row, i) => (
                <tr>
                  <td class="text-muted font-bold">{i + 1}</td>
                  <td class="font-medium">
                    {meta.key === 'events'
                      ? formatValue(row.label, 'date_string', row, 'label')
                      : row.label}
                  </td>
                  <td class="font-bold" style="line-height: 1.2;">
                    {formatValue(row.value, meta.format, row, 'value')}
                  </td>
                  {meta.extra_cols?.map(col => (
                    <td style="line-height: 1.3;">
                      {col.format === 'athlete_time_pair' ? (
                        row[`${col.key}_name`] || row[`${col.key}_time`] ? (
                          <>
                            <span class="font-medium">{row[`${col.key}_name`] || 'Unknown'}</span>
                            <br />
                            <span class="text-xs opacity-80">{row[`${col.key}_time`] || '-'}</span>
                          </>
                        ) : '-'
                      ) : (
                        formatValue(row[col.key], col.format, row, col.key)
                      )}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <div class="back-to-top-container">
        <a href="#top" class="back-to-top">
          Back to top ↑
        </a>
      </div>
    ))
  }
</div>

<style>
  .top-lists-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .jump-menu {
    background: white;
    border: 1px solid #f3f4f6;
    padding: 1rem;
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .menu-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    margin: 0;
  }
  .menu-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .menu-links a {
    font-size: 0.875rem;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
    background: #eff6ff;
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
  }
  .menu-links a:hover {
    background: #dbeafe;
  }

  .back-to-top-container {
    text-align: right;
    margin-top: -1rem;
    margin-bottom: 1rem;
  }

  .back-to-top {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .back-to-top:hover {
    color: #2563eb;
  }

  .table-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 1.5rem;
    overflow: hidden;
    scroll-margin-top: 2rem;
  }
  .table-container {
    width: 100%;
    overflow-x: auto;
  }
  .table-header-box {
    padding: 1.5rem 1.5rem 0 1.5rem;
  }
  .card-title {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .data-table th,
  .data-table td {
    padding: 1rem 1.25rem;
    vertical-align: top; /* Ensure content aligns to top for multi-line cells */
    border: 1px solid #e5e7eb;
  }
  .data-table th {
    text-align: left;
    background: #f9fafb;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .data-table tr:nth-child(even) {
    background-color: #fafafa;
  }
  .text-right {
    text-align: right;
  }
  .text-muted {
    color: var(--text-muted);
  }
  .font-medium {
    font-weight: 500;
  }
  .font-bold {
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .data-table {
      font-size: 0.75rem;
    }
    .data-table th,
    .data-table td {
      padding: 0.75rem 0.5rem;
    }
  }
</style>
