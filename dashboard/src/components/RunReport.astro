---
import { runQuery } from '../lib/bigquery';

const projectId = import.meta.env.GCP_PROJECT_ID;
const datasetId = import.meta.env.BIGQUERY_DATASET_ID || 'parkrun_data';

let targetRunId = parseInt(Astro.url.searchParams.get('run') || '', 10);
if (isNaN(targetRunId)) targetRunId = -1;

/**
 * This query fetches stats for the latest run and compares them to the previous run.
 * It calculates: Finishers, Volunteers, New Parkrunners (RunTotal=1), and PBs.
 */
const reportQuery = `
  WITH AllRuns AS (
    SELECT run_id, event_date 
    FROM \`${projectId}.${datasetId}.results\` 
    GROUP BY 1, 2
  ),
  OrderedRuns AS (
    SELECT *, 
           LAG(run_id) OVER (ORDER BY event_date ASC) as prev_id,
           LEAD(run_id) OVER (ORDER BY event_date ASC) as next_id
    FROM AllRuns
  ),
  CurrentRun AS (
    SELECT * FROM OrderedRuns 
    WHERE (@targetRunId = -1 AND run_id = (SELECT MAX(run_id) FROM AllRuns))
       OR (run_id = @targetRunId)
  ),
  LatestRuns AS (
    SELECT run_id, event_date FROM CurrentRun
    UNION ALL
    SELECT run_id, event_date FROM AllRuns WHERE run_id = (SELECT prev_id FROM CurrentRun)
  ),
  RunMetrics AS (
    SELECT
      r.run_id,
      ANY_VALUE(r.event_date) as event_date,
      COUNT(*) as finishers,
      COUNTIF(r.was_first_run_at_event = true AND r.is_unknown_athlete = false) as first_timers,
      COUNTIF(r.run_total = 1 AND r.is_unknown_athlete = false) as new_parkrunners,
      COUNTIF(r.was_genuine_pb = true) as pbs,
      COUNTIF(r.is_unknown_athlete = true) as unknowns,
      (SELECT COUNT(DISTINCT athlete_id) FROM \`${projectId}.${datasetId}.volunteers\` v WHERE v.run_id = r.run_id) as volunteers,
      MIN(
        CASE
          WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 3 THEN
            CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 3600 + CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64) * 60 + CAST(SPLIT(finish_time, ':')[OFFSET(2)] AS INT64)
          WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 2 THEN
            CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 60 + CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64)
          ELSE NULL
        END
      ) as fastest_s,
      MAX(
        CASE
          WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 3 THEN
            CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 3600 + CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64) * 60 + CAST(SPLIT(finish_time, ':')[OFFSET(2)] AS INT64)
          WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 2 THEN
            CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 60 + CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64)
          ELSE NULL
        END
      ) as slowest_s,
      AVG(
        CASE
          WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 3 THEN
            CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 3600 + CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64) * 60 + CAST(SPLIT(finish_time, ':')[OFFSET(2)] AS INT64)
          WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 2 THEN
            CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 60 + CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64)
          ELSE NULL
        END
      ) as mean_s
    FROM \`${projectId}.${datasetId}.results\` r
    WHERE r.run_id IN (SELECT run_id FROM LatestRuns)
    GROUP BY 1
  ),
  FirstFinishers AS (
    SELECT 
      run_id,
      first_name,
      last_name,
      finish_time,
      age_grading,
      finish_position,
      CASE 
        WHEN age_category LIKE 'M%' OR age_category LIKE 'JM%' OR age_category LIKE 'SM%' OR age_category LIKE 'VM%' THEN 'Male'
        ELSE 'Female'
      END as gender,
      ROW_NUMBER() OVER (PARTITION BY run_id, 
        CASE 
          WHEN age_category LIKE 'M%' OR age_category LIKE 'JM%' OR age_category LIKE 'SM%' OR age_category LIKE 'VM%' THEN 'Male'
          ELSE 'Female'
        END 
        ORDER BY finish_position ASC) as rn
    FROM \`${projectId}.${datasetId}.results\`
    WHERE run_id = (SELECT MAX(run_id) FROM LatestRuns)
  ),
  Milestones AS (
    SELECT * FROM (
      -- Run Milestones
      SELECT 
        first_name, last_name, athlete_id, run_total as count, 'Run' as type
      FROM \`${projectId}.${datasetId}.results\`
      WHERE run_id = (SELECT MAX(run_id) FROM LatestRuns)
        AND run_total IN (10, 25, 50, 100, 250, 500)
      
      UNION ALL

      -- Volunteer Milestones
      SELECT 
        ANY_VALUE(v.first_name) as first_name, 
        ANY_VALUE(v.last_name) as last_name, 
        v.athlete_id,
        GREATEST(
          IFNULL((
            SELECT MAX(vol_count) 
            FROM \`${projectId}.${datasetId}.results\` r 
            WHERE r.athlete_id = v.athlete_id 
              AND r.event_date <= (SELECT event_date FROM CurrentRun)
          ), 0),
          IFNULL((
            SELECT COUNT(DISTINCT event_date) 
            FROM \`${projectId}.${datasetId}.volunteers\` vsum 
            WHERE vsum.athlete_id = v.athlete_id 
              AND vsum.event_date <= (SELECT event_date FROM CurrentRun)
          ), 0)
        ) as count,
        'Volunteer' as type
      FROM \`${projectId}.${datasetId}.volunteers\` v
      WHERE v.run_id = (SELECT MAX(run_id) FROM LatestRuns) AND v.athlete_id IS NOT NULL
      GROUP BY v.athlete_id
    ) WHERE count IN (10, 25, 50, 100, 250, 500)
  ),
  Distribution AS (
    SELECT 
      CAST(FLOOR(
        CASE
          WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 3 THEN
            CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 60 + CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64)
          WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 2 THEN
            CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64)
          ELSE 0
        END
      ) AS INT64) as minute_bucket,
      COUNT(*) as count
    FROM \`${projectId}.${datasetId}.results\`
    WHERE run_id = (SELECT MAX(run_id) FROM LatestRuns)
      AND finish_time IS NOT NULL AND finish_time != ''
    GROUP BY 1
  )
  SELECT 
    (SELECT AS STRUCT 
        *,
        CASE
          WHEN fastest_s >= 3600 THEN FORMAT('%02d:%02d:%02d', CAST(DIV(fastest_s, 3600) AS INT64), CAST(DIV(MOD(fastest_s, 3600), 60) AS INT64), CAST(MOD(fastest_s, 60) AS INT64))
          ELSE FORMAT('%02d:%02d', CAST(DIV(fastest_s, 60) AS INT64), CAST(MOD(fastest_s, 60) AS INT64))
        END as fastest_time,
        CASE
          WHEN slowest_s >= 3600 THEN FORMAT('%02d:%02d:%02d', CAST(DIV(slowest_s, 3600) AS INT64), CAST(DIV(MOD(slowest_s, 3600), 60) AS INT64), CAST(MOD(slowest_s, 60) AS INT64))
          ELSE FORMAT('%02d:%02d', CAST(DIV(slowest_s, 60) AS INT64), CAST(MOD(slowest_s, 60) AS INT64))
        END as slowest_time,
        CASE
          WHEN mean_s >= 3600 THEN FORMAT('%02d:%02d:%02d', CAST(DIV(CAST(ROUND(mean_s) AS INT64), 3600) AS INT64), CAST(DIV(MOD(CAST(ROUND(mean_s) AS INT64), 3600), 60) AS INT64), CAST(MOD(CAST(ROUND(mean_s) AS INT64), 60) AS INT64))
          ELSE FORMAT('%02d:%02d', CAST(DIV(CAST(ROUND(mean_s) AS INT64), 60) AS INT64), CAST(MOD(CAST(ROUND(mean_s) AS INT64), 60) AS INT64))
        END as mean_time
     FROM RunMetrics 
     WHERE run_id = (SELECT MAX(run_id) FROM LatestRuns)) as latest,
    (SELECT AS STRUCT * FROM RunMetrics WHERE run_id = (SELECT MIN(run_id) FROM LatestRuns)) as previous,
    ARRAY(SELECT AS STRUCT * FROM FirstFinishers WHERE rn = 1 ORDER BY finish_position ASC) as first_finishers,
    ARRAY(SELECT AS STRUCT * FROM Milestones ORDER BY count DESC, type ASC) as milestones,
    ARRAY(SELECT AS STRUCT * FROM Distribution ORDER BY minute_bucket ASC) as distribution,
    (SELECT prev_id FROM CurrentRun) as prev_run_id,
    (SELECT next_id FROM CurrentRun) as next_run_id
`;

let data = null;
try {
  const results = await runQuery(reportQuery, { targetRunId });
  data = results[0];
} catch (e) {
  console.error('Run Report Error:', e);
}

const latest = data?.latest || {};
const prev = data?.previous || {};
const firsts = data?.first_finishers || [];
const milestones = data?.milestones || [];
const dist = data?.distribution || [];

// Weather Fetching Logic (Open-Meteo)
let weather = null;
const wDate =
  latest.event_date instanceof Date
    ? latest.event_date
    : new Date(latest.event_date?.value || latest.event_date);

if (!isNaN(wDate.getTime())) {
  const dateStr = wDate.toISOString().split('T')[0];
  try {
    const wRes = await fetch(
      `https://api.open-meteo.com/v1/forecast?latitude=50.7123&longitude=-2.4651&start_date=${dateStr}&end_date=${dateStr}&hourly=temperature_2m,weather_code,wind_speed_10m&wind_speed_unit=mph&timezone=GMT`,
    );
    const wData = await wRes.json();
    if (wData.hourly && wData.hourly.temperature_2m) {
      weather = {
        temp: wData.hourly.temperature_2m[9], // 09:00 GMT
        code: wData.hourly.weather_code[9],
        wind: wData.hourly.wind_speed_10m[9],
      };
    }
  } catch (e) {
    console.error('Weather fetch failed:', e);
  }
}

const weatherCodes = {
  0: { label: 'Sunny', icon: '☀️' },
  1: { label: 'Mostly Clear', icon: '🌤️' },
  2: { label: 'Partly Cloudy', icon: '⛅' },
  3: { label: 'Cloudy', icon: '☁️' },
  45: { label: 'Foggy', icon: '🌫️' },
  48: { label: 'Foggy', icon: '🌫️' },
  51: { label: 'Drizzle', icon: '🌦️' },
  53: { label: 'Drizzle', icon: '🌦️' },
  55: { label: 'Drizzle', icon: '🌦️' },
  61: { label: 'Light Rain', icon: '🌧️' },
  63: { label: 'Rain', icon: '🌧️' },
  65: { label: 'Heavy Rain', icon: '🌧️' },
  71: { label: 'Slight Snow', icon: '❄️' },
  73: { label: 'Snow', icon: '❄️' },
  75: { label: 'Heavy Snow', icon: '❄️' },
  80: { label: 'Showers', icon: '🌦️' },
  81: { label: 'Showers', icon: '🌦️' },
  82: { label: 'Heavy Showers', icon: '⛈️' },
};
const weatherInfo = weather
  ? weatherCodes[weather.code] || { label: 'Unknown', icon: '🌡️' }
  : null;

const getTrend = (curr, old) => {
  if (old === undefined || old === null)
    return { val: 0, icon: '−', color: 'neutral' };
  const diff = curr - old;
  if (diff > 0) return { val: diff, icon: '↑', color: 'up' };
  if (diff < 0) return { val: Math.abs(diff), icon: '↓', color: 'down' };
  return { val: 0, icon: '−', color: 'neutral' };
};

const getTimeTrend = (curr, old) => {
  if (curr === null || curr === undefined || old === null || old === undefined)
    return { val: '−', icon: '', color: 'neutral' };
  const diff = curr - old;
  const absDiff = Math.abs(diff);
  const mins = Math.floor(absDiff / 60);
  const secs = Math.round(absDiff % 60);
  const formatted =
    mins > 0 ? `${mins}:${secs.toString().padStart(2, '0')}` : `${secs}s`;

  if (diff < 0) return { val: formatted, icon: '↑', color: 'up' }; // Faster (numerically lower)
  if (diff > 0) return { val: formatted, icon: '↓', color: 'down' }; // Slower (numerically higher)
  return { val: '0s', icon: '−', color: 'neutral' };
};

const trends = {
  finishers: getTrend(latest.finishers, prev.finishers),
  volunteers: getTrend(latest.volunteers, prev.volunteers),
  first_timers: getTrend(latest.first_timers, prev.first_timers),
  new_parkrunners: getTrend(latest.new_parkrunners, prev.new_parkrunners),
  pbs: getTrend(latest.pbs, prev.pbs),
  unknowns: getTrend(latest.unknowns, prev.unknowns),
  fastest: getTimeTrend(latest.fastest_s, prev.fastest_s),
  mean: getTimeTrend(latest.mean_s, prev.mean_s),
  slowest: getTimeTrend(latest.slowest_s, prev.slowest_s),
};

const chartLabels = dist.map(d => `${d.minute_bucket}:00`);
const chartData = dist.map(d => d.count);
---

<div class="report-container">
  {
    !data && (
      <div class="error-card">
        <p>
          Could not find report for Event #
          {targetRunId === -1 ? 'Latest' : targetRunId}. Please verify the event
          number or use the navigation below.
        </p>
      </div>
    )
  }
  <header class="report-header">
    <h2 class="section-title">Event #{latest.run_id} Report</h2>
    <p class="event-date">
      {
        (() => {
          const d = latest.event_date;
          if (!d) return 'Unknown Date';
          const date = d instanceof Date ? d : new Date(d.value || d);
          return isNaN(date.getTime())
            ? 'Unknown Date'
            : date.toLocaleDateString('en-GB').split('/').join('-');
        })()
      }
    </p>
  </header>

  <div class="stats-grid">
    <div class="stat-card">
      <span class="stat-label">Finishers</span>
      <div class="stat-main">
        <span class="stat-value">{latest.finishers || 0}</span>
        <span class:list={['trend-tag', trends.finishers.color]}>
          {trends.finishers.icon}
          {trends.finishers.val}
        </span>
      </div>
    </div>

    <div class="stat-card">
      <span class="stat-label">Volunteers</span>
      <div class="stat-main">
        <span class="stat-value">{latest.volunteers || 0}</span>
        <span class:list={['trend-tag', trends.volunteers.color]}>
          {trends.volunteers.icon}
          {trends.volunteers.val}
        </span>
      </div>
    </div>

    <div class="stat-card">
      <span class="stat-label">New parkrunners</span>
      <div class="stat-main">
        <span class="stat-value">{latest.new_parkrunners || 0}</span>
        <span class:list={['trend-tag', trends.new_parkrunners.color]}>
          {trends.new_parkrunners.icon}
          {trends.new_parkrunners.val}
        </span>
      </div>
    </div>

    <div class="stat-card">
      <span class="stat-label">TGF First Timers</span>
      <div class="stat-main">
        <span class="stat-value">{latest.first_timers || 0}</span>
        <span class:list={['trend-tag', trends.first_timers.color]}>
          {trends.first_timers.icon}
          {trends.first_timers.val}
        </span>
      </div>
    </div>

    <div class="stat-card">
      <span class="stat-label">Unknown Athletes</span>
      <div class="stat-main">
        <span class="stat-value">{latest.unknowns || 0}</span>
        <span class:list={['trend-tag', trends.unknowns.color]}>
          {trends.unknowns.icon}
          {trends.unknowns.val}
        </span>
      </div>
    </div>

    <div class="stat-card">
      <span class="stat-label">PB's Achieved</span>
      <div class="stat-main">
        <span class="stat-value">{latest.pbs || 0}</span>
        <span class:list={['trend-tag', trends.pbs.color]}>
          {trends.pbs.icon}
          {trends.pbs.val}
        </span>
      </div>
    </div>

    <div class="stat-card ff-card">
      <h3 class="card-title">First Finishers</h3>
      <div class="first-finishers-list">
        {
          firsts.map(f => (
            <div class="ff-item">
              <div class="ff-meta">
                <span class="ff-gender">{f.gender}</span>
                <span class="ff-name">
                  {f.first_name} {f.last_name}
                </span>
              </div>
              <div class="ff-stats">
                <span class="ff-time">{f.finish_time}</span>
                <span class="ff-grading">{f.age_grading?.toFixed(2)}%</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="stat-card time-stats-card">
      <h3 class="card-title">Run Times</h3>
      <div class="time-stats-list">
        <div class="time-stat-row">
          <span class="ts-label">Fastest</span>
          <div class="ts-result">
            <span class="ts-value">{latest.fastest_time || '-'}</span>
            <span class:list={['trend-tag', trends.fastest.color]}>
              {trends.fastest.icon}
              {trends.fastest.val}
            </span>
          </div>
        </div>
        <div class="time-stat-row">
          <span class="ts-label">Average</span>
          <div class="ts-result">
            <span class="ts-value">{latest.mean_time || '-'}</span>
            <span class:list={['trend-tag', trends.mean.color]}>
              {trends.mean.icon}
              {trends.mean.val}
            </span>
          </div>
        </div>
        <div class="time-stat-row">
          <span class="ts-label">Slowest</span>
          <div class="ts-result">
            <span class="ts-value">{latest.slowest_time || '-'}</span>
            <span class:list={['trend-tag', trends.slowest.color]}>
              {trends.slowest.icon}
              {trends.slowest.val}
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="stat-card weather-card">
      <span class="stat-label">Weather at 09:00</span>
      <div class="stat-main">
        <span class="stat-value">
          {weather ? `${Math.round(weather.temp)}°C` : 'N/A'}
          <span class="weather-icon">{weatherInfo?.icon}</span>
        </span>

        <span class="trend-tag neutral">
          {weather ? weatherInfo?.label : '-'}
        </span>
      </div>
      {
        weather && (
          <span class="weather-sub">Wind: {Math.round(weather.wind)} mph</span>
        )
      }
    </div>
  </div>

  <div class="report-content">
    <div class="content-card chart-card">
      <h3 class="card-title">Finish Time Distribution</h3>
      <div class="canvas-wrapper">
        <canvas id="distributionChart"></canvas>
      </div>
    </div>

    <div class="content-card">
      <h3 class="card-title">Milestones Achieved</h3>
      {
        milestones.length > 0 ? (
          <ul class="milestone-list">
            {milestones.map(m => (
              <li>
                <div class="m-info">
                  <span class="m-name">
                    {m.first_name} {m.last_name}
                  </span>
                  <span class:list={['m-type', m.type.toLowerCase()]}>
                    {m.type === 'Run' ? '🏃 Run' : '🙌 Vol'}
                  </span>
                </div>
                <span class={`badge m-${m.count}`}>{m.count}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty-state">No run milestones today.</p>
        )
      }
    </div>
  </div>

  <nav class="report-pagination">
    {
      data?.prev_run_id && (
        <a href={`/run-report?run=${data.prev_run_id}`} class="pag-link prev">
          ← Event #{data.prev_run_id}
        </a>
      )
    }
    <div class="pag-spacer"></div>
    {
      data?.next_run_id && (
        <a href={`/run-report?run=${data.next_run_id}`} class="pag-link next">
          Event #{data.next_run_id} →
        </a>
      )
    }
  </nav>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script define:vars={{ chartLabels, chartData }}>
  function initChart() {
    const canvas = document.getElementById('distributionChart');
    if (!canvas) return;

    // Wait for the Chart.js library to load from the CDN
    if (typeof Chart === 'undefined') {
      setTimeout(initChart, 100);
      return;
    }

    // Ensure we don't try to re-use a canvas that already has a chart
    const existingChart = Chart.getChart(canvas);
    if (existingChart) {
      existingChart.destroy();
    }

    new Chart(canvas, {
      type: 'bar',
      data: {
        labels: chartLabels,
        datasets: [
          {
            label: 'Finishers',
            data: chartData,
            backgroundColor: '#3b82f6',
            borderRadius: 4,
            barPercentage: 0.8,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, grid: { display: false } },
          x: { grid: { display: false } },
        },
      },
    });
  }
  initChart();
  document.addEventListener('astro:page-load', initChart);
</script>

<style>
  .report-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .report-header {
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: 1.875rem;
    font-weight: 900;
    color: var(--text-main);
    margin: 0;
  }

  .event-date {
    color: var(--text-muted);
    font-weight: 600;
    margin: 0.25rem 0 0 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .stat-card {
    background: white;
    padding: 1.25rem;
    border-radius: 1.25rem;
    border: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .stat-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--text-main);
  }

  .trend-tag {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
  }

  .trend-tag.up {
    background: #ecfdf5;
    color: #059669;
  }
  .trend-tag.down {
    background: #fef2f2;
    color: #dc2626;
  }
  .trend-tag.neutral {
    background: #f9fafb;
    color: #6b7280;
  }

  .report-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .weather-card {
      grid-column: span 3;
    }
    .ff-card {
      grid-column: span 2;
    }
    .time-stats-card {
      grid-column: span 1;
    }
  }

  @media (max-width: 1023px) {
    .weather-card,
    .ff-card,
    .time-stats-card {
      grid-column: span 2;
    }
  }

  .weather-icon {
