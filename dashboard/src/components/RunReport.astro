---
import { runQuery } from '../lib/bigquery';

const projectId = import.meta.env.GCP_PROJECT_ID;
const viewsDatasetId =
  import.meta.env.BIGQUERY_VIEWS_DATASET_ID ||
  import.meta.env.BIGQUERY_DATASET_ID ||
  'parkrun_data';
const dataDatasetId = import.meta.env.BIGQUERY_DATASET_ID || 'parkrun_data';
const weatherTableId =
  import.meta.env.BIGQUERY_WEATHER_TABLE || 'event_weather';

let targetRunId = parseInt(Astro.url.searchParams.get('run') || '', 10);
if (isNaN(targetRunId)) targetRunId = -1;

/**
 * This query fetches stats for the latest run and compares them to the previous run.
 * It calculates: Finishers, Volunteers, New Parkrunners (RunTotal=1), and PBs.
 */
const reportQuery = `
  SELECT
    STRUCT(
      run_id,
      event_date,
      finishers,
      first_timers,
      new_parkrunners,
      pbs,
      unknowns,
      volunteers,
      fastest_s,
      slowest_s,
      mean_s,
      fastest_time,
      slowest_time,
      mean_time
    ) AS latest,
    STRUCT(
      previous_finishers AS finishers,
      previous_first_timers AS first_timers,
      previous_new_parkrunners AS new_parkrunners,
      previous_pbs AS pbs,
      previous_unknowns AS unknowns,
      previous_volunteers AS volunteers,
      previous_fastest_s AS fastest_s,
      previous_slowest_s AS slowest_s,
      previous_mean_s AS mean_s
    ) AS previous,
    first_finishers,
    distribution,
    top_age_grades,
    visitors,
    prev_run_id,
    next_run_id
  FROM \`${projectId}.${viewsDatasetId}._26_dashboard_run_report\`
  WHERE (@targetRunId = -1 AND run_id = (
      SELECT MAX(run_id)
      FROM \`${projectId}.${viewsDatasetId}._26_dashboard_run_report\`
    ))
    OR run_id = @targetRunId
`;

let data: any = null;
try {
  const results = await runQuery(reportQuery, { targetRunId });
  data = results[0];
} catch (e) {
  console.error('Run Report Error:', e);
}

const latest = data?.latest || {};
const prev = data?.previous || {};
const firsts = data?.first_finishers || [];
const dist = data?.distribution || [];
const topAgeGrades = data?.top_age_grades || [];
const visitors = data?.visitors || [];

// Weather is sourced from BigQuery to avoid blocking SSR with external API calls.
let weather: { temp: number; code: number; wind: number } | null = null;
const latestRunId = Number(latest.run_id?.value || latest.run_id);

if (!isNaN(latestRunId)) {
  const weatherQuery = `
    SELECT
      temp_c,
      weather_code,
      wind_mph
    FROM \`${projectId}.${dataDatasetId}.${weatherTableId}\`
    WHERE run_id = @runId
    LIMIT 1
  `;

  try {
    const weatherRows = await runQuery(weatherQuery, { runId: latestRunId });
    const weatherRow = weatherRows?.[0];
    if (weatherRow) {
      weather = {
        temp: Number(weatherRow.temp_c),
        code: Number(weatherRow.weather_code),
        wind: Number(weatherRow.wind_mph),
      };
    }
  } catch (e) {
    console.error('Weather query failed:', e);
  }
}

const weatherCodes = {
  0: { label: 'Sunny', icon: '☀️' },
  1: { label: 'Mostly Clear', icon: '🌤️' },
  2: { label: 'Partly Cloudy', icon: '⛅' },
  3: { label: 'Cloudy', icon: '☁️' },
  45: { label: 'Foggy', icon: '🌫️' },
  48: { label: 'Foggy', icon: '🌫️' },
  51: { label: 'Drizzle', icon: '🌦️' },
  53: { label: 'Drizzle', icon: '🌦️' },
  55: { label: 'Drizzle', icon: '🌦️' },
  61: { label: 'Light Rain', icon: '🌧️' },
  63: { label: 'Rain', icon: '🌧️' },
  65: { label: 'Heavy Rain', icon: '🌧️' },
  71: { label: 'Slight Snow', icon: '❄️' },
  73: { label: 'Snow', icon: '❄️' },
  75: { label: 'Heavy Snow', icon: '❄️' },
  80: { label: 'Showers', icon: '🌦️' },
  81: { label: 'Showers', icon: '🌦️' },
  82: { label: 'Heavy Showers', icon: '⛈️' },
};
const weatherInfo = weather
  ? weatherCodes[weather.code as keyof typeof weatherCodes] || {
      label: 'Unknown',
      icon: '🌡️',
    }
  : null;

const getTrend = (curr: any, old: any) => {
  if (old === undefined || old === null)
    return { val: 0, icon: '−', color: 'neutral' };
  const diff = curr - old;
  if (diff > 0) return { val: diff, icon: '↑', color: 'up' };
  if (diff < 0) return { val: Math.abs(diff), icon: '↓', color: 'down' };
  return { val: 0, icon: '−', color: 'neutral' };
};

const getTimeTrend = (curr: any, old: any) => {
  if (curr === null || curr === undefined || old === null || old === undefined)
    return { val: '−', icon: '', color: 'neutral' };
  const diff = curr - old;
  const absDiff = Math.abs(diff);
  const mins = Math.floor(absDiff / 60);
  const secs = Math.round(absDiff % 60);
  const formatted =
    mins > 0 ? `${mins}:${secs.toString().padStart(2, '0')}` : `${secs}s`;

  if (diff < 0) return { val: formatted, icon: '↑', color: 'up' }; // Faster (numerically lower)
  if (diff > 0) return { val: formatted, icon: '↓', color: 'down' }; // Slower (numerically higher)
  return { val: '0s', icon: '−', color: 'neutral' };
};

const trends = {
  finishers: getTrend(latest.finishers, prev.finishers),
  volunteers: getTrend(latest.volunteers, prev.volunteers),
  first_timers: getTrend(latest.first_timers, prev.first_timers),
  new_parkrunners: getTrend(latest.new_parkrunners, prev.new_parkrunners),
  pbs: getTrend(latest.pbs, prev.pbs),
  unknowns: getTrend(latest.unknowns, prev.unknowns),
  fastest: getTimeTrend(latest.fastest_s, prev.fastest_s),
  mean: getTimeTrend(latest.mean_s, prev.mean_s),
  slowest: getTimeTrend(latest.slowest_s, prev.slowest_s),
};

const chartLabels = dist.map((d: any) => `${d.minute_bucket}:00`);
const chartData = dist.map((d: any) => d.count);
---

<div class="report-container">
  {
    !data && (
      <div class="error-card">
        <p>
          Could not find report for Event #
          {targetRunId === -1 ? 'Latest' : targetRunId}. Please verify the event
          number or use the navigation below.
        </p>
      </div>
    )
  }
  <header class="report-header-wrapper">
    <div class="report-header">
      <h2 class="section-title">Event #{latest.run_id} Report</h2>
      <p class="event-date">
        {
          (() => {
            const d = latest.event_date;
            if (!d) return 'Unknown Date';
            const date = d instanceof Date ? d : new Date(d.value || d);
            return isNaN(date.getTime())
              ? 'Unknown Date'
              : date.toLocaleDateString('en-GB').split('/').join('-');
          })()
        }
      </p>
    </div>
  </header>

  <div class="stats-grid">
    <div class="stat-card">
      <span class="stat-label">Finishers</span>
      <div class="stat-main">
        <span class="stat-value">{latest.finishers || 0}</span>
        <span class:list={['trend-tag', trends.finishers.color]}>
          {trends.finishers.icon}
          {trends.finishers.val}
        </span>
      </div>
    </div>

    <div class="stat-card">
      <span class="stat-label">Volunteers</span>
      <div class="stat-main">
        <span class="stat-value">{latest.volunteers || 0}</span>
        <span class:list={['trend-tag', trends.volunteers.color]}>
          {trends.volunteers.icon}
          {trends.volunteers.val}
        </span>
      </div>
    </div>

    <div class="stat-card">
      <span class="stat-label">New parkrunners</span>
      <div class="stat-main">
        <span class="stat-value">{latest.new_parkrunners || 0}</span>
        <span class:list={['trend-tag', trends.new_parkrunners.color]}>
          {trends.new_parkrunners.icon}
          {trends.new_parkrunners.val}
        </span>
      </div>
    </div>

    <div class="stat-card">
      <span class="stat-label">TGF First Timers</span>
      <div class="stat-main">
        <span class="stat-value">{latest.first_timers || 0}</span>
        <span class:list={['trend-tag', trends.first_timers.color]}>
          {trends.first_timers.icon}
          {trends.first_timers.val}
        </span>
      </div>
    </div>

    <div class="stat-card">
      <span class="stat-label">Unknown Athletes</span>
      <div class="stat-main">
        <span class="stat-value">{latest.unknowns || 0}</span>
        <span class:list={['trend-tag', trends.unknowns.color]}>
          {trends.unknowns.icon}
          {trends.unknowns.val}
        </span>
      </div>
    </div>

    <div class="stat-card">
      <span class="stat-label">PB's Achieved</span>
      <div class="stat-main">
        <span class="stat-value">{latest.pbs || 0}</span>
        <span class:list={['trend-tag', trends.pbs.color]}>
          {trends.pbs.icon}
          {trends.pbs.val}
        </span>
      </div>
    </div>

    <div class="stat-card ff-card">
      <h3 class="card-title">First Finishers</h3>
      <div class="first-finishers-list">
        {
          firsts.map((f: any) => (
            <div class="ff-item">
              <div class="ff-meta">
                <span class="ff-gender">{f.gender}</span>
                <span class="ff-name">
                  {f.first_name} {f.last_name}
                </span>
              </div>
              <div class="ff-stats">
                <span class="ff-time">{f.finish_time}</span>
                <span class="ff-grading">{f.age_grading?.toFixed(2)}%</span>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="stat-card time-stats-card">
      <h3 class="card-title">Run Times</h3>
      <div class="time-stats-list">
        <div class="time-stat-row">
          <span class="ts-label">Fastest</span>
          <div class="ts-result">
            <span class="ts-value">{latest.fastest_time || '-'}</span>
            <span class:list={['trend-tag', trends.fastest.color]}>
              {trends.fastest.icon}
              {trends.fastest.val}
            </span>
          </div>
        </div>
        <div class="time-stat-row">
          <span class="ts-label">Average</span>
          <div class="ts-result">
            <span class="ts-value">{latest.mean_time || '-'}</span>
            <span class:list={['trend-tag', trends.mean.color]}>
              {trends.mean.icon}
              {trends.mean.val}
            </span>
          </div>
        </div>
        <div class="time-stat-row">
          <span class="ts-label">Slowest</span>
          <div class="ts-result">
            <span class="ts-value">{latest.slowest_time || '-'}</span>
            <span class:list={['trend-tag', trends.slowest.color]}>
              {trends.slowest.icon}
              {trends.slowest.val}
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="stat-card weather-card">
      <span class="stat-label">Weather at event</span>
      <div class="stat-main">
        <span class="stat-value">
          {weather ? `${Math.round(weather.temp)}°C` : 'N/A'}
          <span class="weather-icon">{weatherInfo?.icon}</span>
        </span>

        <span class="trend-tag neutral">
          {weather ? weatherInfo?.label : '-'}
        </span>
      </div>
      {
        weather && (
          <span class="weather-sub">Wind: {Math.round(weather.wind)} mph</span>
        )
      }
    </div>
  </div>

  <div class="report-content">
    <div class="content-card chart-card">
      <h3 class="card-title">Finish Time Distribution</h3>
      <div class="canvas-wrapper">
        <div id="distributionChart"></div>
      </div>
    </div>

    <div class="content-card">
      <h3 class="card-title">Highest Age Grades</h3>
      <div class="age-grade-grid">
        {
          topAgeGrades.map((ag: any) => (
            <div class="ag-item">
              <div class="ag-info">
                <span class="ag-name">
                  {ag.first_name} {ag.last_name}
                </span>
                <span class="ag-meta">
                  {ag.age_category} • {ag.finish_time}
                </span>
              </div>
              <div class="ag-score">
                <span
                  class:list={[
                    'ag-badge',
                    {
                      gold: ag.age_grading >= 80,
                      silver: ag.age_grading >= 70 && ag.age_grading < 80,
                      bronze: ag.age_grading < 70,
                    },
                  ]}
                >
                  {ag.age_grading?.toFixed(2)}%
                </span>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="content-card">
      <h3 class="card-title">Visitors From</h3>
      <div class="visitors-container">
        {
          visitors.length > 0 ? (
            <div class="visitors-tags">
              {visitors.map((v: any) => (
                <div class="v-tag">
                  <span class="v-name">{v.home_run_name}</span>
                  <span class="v-count">{v.count}</span>
                </div>
              ))}
            </div>
          ) : (
            <p class="empty-state">No visitors from other parkruns recorded.</p>
          )
        }
      </div>
    </div>
  </div>

  <nav class="report-pagination">
    {
      data?.prev_run_id && (
        <a href={`/run-report?run=${data.prev_run_id}`} class="pag-link prev">
          ← Event #{data.prev_run_id}
        </a>
      )
    }
    <div class="pag-spacer"></div>
    {
      data?.next_run_id && (
        <a href={`/run-report?run=${data.next_run_id}`} class="pag-link next">
          Event #{data.next_run_id} →
        </a>
      )
    }
  </nav>
</div>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script define:vars={{ chartLabels, chartData }}>
  function initChart() {
    const container = document.getElementById('distributionChart');
    if (!container) return;

    // Wait for the ApexCharts library to load from the CDN
    if (typeof ApexCharts === 'undefined') {
      setTimeout(initChart, 100);
      return;
    }

    // Clear container for idempotent re-initialization (Astro View Transitions)
    container.innerHTML = '';

    const options = {
      series: [
        {
          name: 'Finishers',
          data: chartData,
        },
      ],
      chart: {
        type: 'bar',
        height: 300,
        toolbar: { show: false },
        animations: { enabled: true },
      },
      plotOptions: {
        bar: {
          borderRadius: 4,
          columnWidth: '70%',
        },
      },
      dataLabels: { enabled: false },
      colors: ['#3b82f6'],
      xaxis: {
        categories: chartLabels,
        labels: { style: { fontSize: '12px', fontWeight: 600 } },
      },
      yaxis: {
        labels: { style: { fontSize: '12px' } },
      },
      grid: { borderColor: '#f3f4f6' },
    };

    const chart = new ApexCharts(container, options);
    chart.render();
  }
  initChart();
  document.addEventListener('astro:page-load', initChart);
</script>

<style>
  .report-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .report-header-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.5rem;
    gap: 1rem;
  }

  .report-header {
    flex: 1;
  }

  .section-title {
    font-size: 1.875rem;
    font-weight: 900;
    color: var(--text-main);
    margin: 0;
  }

  .event-date {
    color: var(--text-muted);
    font-weight: 600;
    margin: 0.25rem 0 0 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .stat-card {
    background: white;
    padding: 1.25rem;
    border-radius: 1.25rem;
    border: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .stat-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--text-main);
  }

  .trend-tag {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
  }

  .trend-tag.up {
    background: #ecfdf5;
    color: #059669;
  }
  .trend-tag.down {
    background: #fef2f2;
    color: #dc2626;
  }
  .trend-tag.neutral {
    background: #f9fafb;
    color: #6b7280;
  }

  .report-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .weather-card {
      grid-column: span 3;
    }
    .ff-card {
      grid-column: span 2;
    }
    .time-stats-card {
      grid-column: span 1;
    }
  }

  @media (max-width: 1023px) {
    .weather-card,
    .ff-card,
    .time-stats-card {
      grid-column: span 2;
    }
  }

  .weather-icon {
    font-size: 1.25rem;
    margin-left: 0.5rem;
  }

  .weather-sub {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-top: -0.25rem;
  }

  .content-card {
    background: white;
    padding: 1.5rem;
    border-radius: 1.5rem;
    border: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 800;
    color: var(--text-main);
    margin: 0;
  }

  .canvas-wrapper {
    height: 300px;
    position: relative;
  }

  .age-grade-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ag-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem;
    background: #f9fafb;
    border-radius: 0.75rem;
    border: 1px solid #f3f4f6;
  }

  .ag-info {
    display: flex;
    flex-direction: column;
  }
  .ag-name {
    font-weight: 700;
    color: var(--text-main);
    font-size: 0.875rem;
  }
  .ag-meta {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .ag-badge {
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.25rem 0.625rem;
    border-radius: 2rem;
    background: #e5e7eb;
    color: #4b5563;
  }

  /* Standard Parkrun Age Grade Colors */
  .ag-badge.gold {
    background: #fef3c7;
    color: #92400e;
  } /* 80%+ */
  .ag-badge.silver {
    background: #ecfdf5;
    color: #065f46;
  } /* 70%+ */
