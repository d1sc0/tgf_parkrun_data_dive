---
import Layout from '../layouts/Layout.astro';
import TopLists from '../components/TopLists.astro';

// Check for user state from middleware (src/middleware.ts)
const user = Astro.locals.user;

// Server-side protection: Redirect to login if not authenticated
if (!user) {
  return Astro.redirect('/login');
}
---

<Layout
  title="Top 20 Lists"
  description="Detailed event leaderboards and community records."
>
  <TopLists />
</Layout>
