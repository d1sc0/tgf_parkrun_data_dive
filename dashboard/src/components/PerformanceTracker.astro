---
import { runQuery } from '../lib/bigquery';

/**
 * Performance Query:
 * We calculate seconds from the finish_time string to allow for MIN/AVG/MAX calculations.
 * We group by category so the client can re-aggregate based on gender/age filters.
 */
const query = `
  SELECT
    event_date,
    run_id,
    CASE
      WHEN age_category LIKE 'W%' OR age_category LIKE 'JW%' OR age_category LIKE 'SW%' OR age_category LIKE 'VW%' THEN 'Female'
      WHEN age_category LIKE 'M%' OR age_category LIKE 'JM%' OR age_category LIKE 'SM%' OR age_category LIKE 'VM%' THEN 'Male'
      ELSE 'Unknown'
    END as gender,
    CASE
      WHEN age_category LIKE 'J%' THEN 'Junior'
      WHEN age_category LIKE 'S%' THEN 'Senior'
      WHEN age_category LIKE 'V%' THEN 'Veteran'
      ELSE 'Other'
    END as age_group,
    age_category,
    MIN(
      CASE
        WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 3 THEN
          CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 3600 +
          CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64) * 60 +
          CAST(SPLIT(finish_time, ':')[OFFSET(2)] AS INT64)
        WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 2 THEN
          CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 60 +
          CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64)
        ELSE NULL
      END
    ) as fastest_seconds,
    AVG(
      CASE
        WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 3 THEN
          CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 3600 +
          CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64) * 60 +
          CAST(SPLIT(finish_time, ':')[OFFSET(2)] AS INT64)
        WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 2 THEN
          CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 60 +
          CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64)
        ELSE NULL
      END
    ) as average_seconds,
    MAX(
      CASE
        WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 3 THEN
          CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 3600 +
          CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64) * 60 +
          CAST(SPLIT(finish_time, ':')[OFFSET(2)] AS INT64)
        WHEN ARRAY_LENGTH(SPLIT(finish_time, ':')) = 2 THEN
          CAST(SPLIT(finish_time, ':')[OFFSET(0)] AS INT64) * 60 +
          CAST(SPLIT(finish_time, ':')[OFFSET(1)] AS INT64)
        ELSE NULL
      END
    ) as slowest_seconds,
    COUNT(*) as finishers
  FROM \`${import.meta.env.GCP_PROJECT_ID}.parkrun_data.results\`
  WHERE finish_time IS NOT NULL AND finish_time != ""
  GROUP BY event_date, run_id, gender, age_group, age_category
  ORDER BY event_date ASC
`;

let rows = [];
try {
  rows = await runQuery(query);
} catch (e) {
  console.error('BigQuery Error in PerformanceTracker:', e);
}

const data = rows.map(r => ({
  date: r.event_date.value || r.event_date,
  run_id: r.run_id,
  gender: r.gender,
  age_group: r.age_group,
  age_category: r.age_category,
  fastest: Number(r.fastest_seconds),
  average: Number(r.average_seconds),
  slowest: Number(r.slowest_seconds),
  finishers: Number(r.finishers),
}));

const allYears = [...new Set(data.map(d => d.date.substring(0, 4)))]
  .filter(Boolean)
  .sort((a, b) => b.localeCompare(a));
---

<div class="attendance-wrapper">
  <div class="controls-bar">
    <div class="mode-selector">
      <label class="radio-label">
        <input type="radio" name="perf-view-mode" value="timeline" checked />
        <span>Timeline</span>
      </label>
      <label class="radio-label">
        <input type="radio" name="perf-view-mode" value="compare" />
        <span>Compare Years</span>
      </label>
    </div>

    <div class="filter-row">
      <div id="perf-year-dropdown-container" class="filter-group">
        <label for="perf-year-filter">Year</label>
        <select id="perf-year-filter">
          <option value="All">All Years</option>
          {allYears.map(year => <option value={year}>{year}</option>)}
        </select>
      </div>

      <div class="filter-group">
        <label for="perf-gender-filter">Gender</label>
        <select id="perf-gender-filter">
          <option value="All">All Genders</option>
          <option value="Male">Male</option>
          <option value="Female">Female</option>
          <option value="Unknown">Unknown</option>
        </select>
      </div>
      <div class="filter-group">
        <label for="perf-age-filter">Age Category</label>
        <select id="perf-age-filter">
          <option value="All">All Categories</option>
          <option value="Junior">Junior</option>
          <option value="Senior">Senior</option>
          <option value="Veteran">Veteran</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>

    <div id="perf-multi-year-container" class="hidden">
      <div class="filter-group">
        <label>Select Years to Overlay (select 2)</label>
        <div class="checkbox-group">
          {
            allYears.map((year, i) => (
              <label class="checkbox-item">
                <input
                  type="checkbox"
                  value={year}
                  checked={i < 2}
                  class="perf-year-checkbox"
                />
                {year}
              </label>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="chart-card">
    <div id="performance-chart"></div>
  </div>

  <div class="table-card">
    <table class="data-table">
      <thead>
        <tr>
          <th class="sortable" data-col="category"
            >Age Category <span class="sort-icon">↕</span></th
          >
          <th class="text-right sortable" data-col="fastest"
            >Fastest <span class="sort-icon">↕</span></th
          >
          <th class="text-right sortable" data-col="average"
            >Average <span class="sort-icon">↕</span></th
          >
          <th class="text-right sortable" data-col="slowest"
            >Slowest <span class="sort-icon">↕</span></th
          >
        </tr>
      </thead>
      <tbody id="perf-table-body"></tbody>
    </table>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<script define:vars={{ rawData: data }}>
  let chart;
  const genderFilter = document.getElementById('perf-gender-filter');
  const ageFilter = document.getElementById('perf-age-filter');
  const yearFilter = document.getElementById('perf-year-filter');
  const multiYearContainer = document.getElementById(
    'perf-multi-year-container',
  );
  const tableBody = document.getElementById('perf-table-body');
  const modeRadios = document.querySelectorAll('input[name="perf-view-mode"]');
  const yearDropdownContainer = document.getElementById(
    'perf-year-dropdown-container',
  );

  // Sorting State
  let currentSort = { col: 'category', dir: 'asc' };

  document.querySelectorAll('.data-table th.sortable').forEach(th => {
    th.addEventListener('click', () => handleSort(th.dataset.col));
  });

  function formatSeconds(seconds) {
    if (seconds == null || isNaN(seconds)) return '-';
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = Math.round(seconds % 60);
    const mm = m.toString().padStart(2, '0');
    const ss = s.toString().padStart(2, '0');
    return h > 0 ? `${h}:${mm}:${ss}` : `${m}:${ss}`;
  }

  modeRadios.forEach(radio => {
    radio.addEventListener('change', () => {
      const isCompare = radio.value === 'compare';
      multiYearContainer.classList.toggle('hidden', !isCompare);
      yearDropdownContainer.classList.toggle('hidden', isCompare);
      document
        .querySelector('.table-card')
        ?.classList.toggle('hidden', isCompare);
      updateView();
    });
  });

  function handleSort(col) {
    if (currentSort.col === col) {
      currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
    } else {
      currentSort.col = col;
      currentSort.dir = 'asc';
    }
    updateSortIcons();
    updateView();
  }

  function updateView() {
    const viewMode = document.querySelector(
      'input[name="perf-view-mode"]:checked',
    ).value;
    const selectedGender = genderFilter.value;
    const selectedAge = ageFilter.value;
    const selectedYear = yearFilter.value;
    const selectedYears =
      viewMode === 'compare'
        ? Array.from(
            document.querySelectorAll('.perf-year-checkbox:checked'),
          ).map(cb => cb.value)
        : [];

    let filteredRows = rawData.filter(curr => {
      const genderMatch =
        selectedGender === 'All' || curr.gender === selectedGender;
      const ageMatch = selectedAge === 'All' || curr.age_group === selectedAge;
      return genderMatch && ageMatch;
    });

    let series = [];
    let chartOptions = {};

    const aggregateByDate = rows => {
      return rows.reduce((acc, curr) => {
        if (!acc[curr.date])
          acc[curr.date] = {
            fastest: Infinity,
            slowest: 0,
            sumSeconds: 0,
            finishers: 0,
            run_id: curr.run_id,
          };
        acc[curr.date].fastest = Math.min(acc[curr.date].fastest, curr.fastest);
        acc[curr.date].slowest = Math.max(acc[curr.date].slowest, curr.slowest);
        acc[curr.date].sumSeconds += curr.average * curr.finishers;
        acc[curr.date].finishers += curr.finishers;
        return acc;
      }, {});
    };

    if (viewMode === 'timeline') {
      const timelineRows =
        selectedYear === 'All'
          ? filteredRows
          : filteredRows.filter(r => r.date.startsWith(selectedYear));
      const byDate = aggregateByDate(timelineRows);
      const sortedDates = Object.keys(byDate).sort();

      series = [
        {
          name: 'Fastest',
          data: sortedDates.map(d => ({
            x: new Date(d).getTime(),
            y: byDate[d].fastest,
            run_id: byDate[d].run_id,
          })),
        },
        {
          name: 'Average',
          data: sortedDates.map(d => ({
            x: new Date(d).getTime(),
            y: Math.round(byDate[d].sumSeconds / byDate[d].finishers),
            run_id: byDate[d].run_id,
          })),
        },
        {
          name: 'Slowest',
          data: sortedDates.map(d => ({
            x: new Date(d).getTime(),
            y: byDate[d].slowest,
            run_id: byDate[d].run_id,
          })),
        },
      ];

      chartOptions = {
        colors: ['#16a34a', '#2563eb', '#ef4444'],
        xaxis: {
          type: 'datetime',
          labels: { format: selectedYear === 'All' ? 'MMM yyyy' : 'dd MMM' },
        },
        stroke: { width: 3, curve: 'smooth' },
      };
    } else {
      const baseColors = ['#16a34a', '#2563eb', '#ef4444'];
      const dashArray = [];
      selectedYears.forEach((year, yearIdx) => {
        const yearRows = filteredRows.filter(r => r.date.startsWith(year));
        const byDay = yearRows.reduce((acc, curr) => {
          const md = curr.date.substring(5);
          if (!acc[md])
            acc[md] = {
              fastest: Infinity,
              slowest: 0,
              sumSeconds: 0,
              finishers: 0,
              run_id: curr.run_id,
            };
          acc[md].fastest = Math.min(acc[md].fastest, curr.fastest);
          acc[md].slowest = Math.max(acc[md].slowest, curr.slowest);
          acc[md].sumSeconds += curr.average * curr.finishers;
          acc[md].finishers += curr.finishers;
          return acc;
        }, {});

        const sortedDays = Object.keys(byDay).sort();
        const metrics = [
          { name: 'Fastest', key: 'fastest', color: baseColors[0] },
          { name: 'Average', key: 'avg', color: baseColors[1] },
          { name: 'Slowest', key: 'slowest', color: baseColors[2] },
        ];

        metrics.forEach(metric => {
          series.push({
            name: `${year} ${metric.name}`,
            data: sortedDays.map(md => {
              const [m, d] = md.split('-');
              const val =
                metric.key === 'avg'
                  ? Math.round(byDay[md].sumSeconds / byDay[md].finishers)
                  : byDay[md][metric.key];
              return {
                x: new Date(2024, parseInt(m) - 1, parseInt(d)).getTime(),
                y: val,
                run_id: byDay[md].run_id,
              };
            }),
            color: metric.color,
          });
          dashArray.push(yearIdx === 0 ? 0 : 5);
        });
      });
      chartOptions = {
        stroke: { width: 3, curve: 'smooth', dashArray },
        xaxis: { type: 'datetime', labels: { format: 'MMM' } },
      };
    }

    const options = {
      series,
      ...chartOptions,
      chart: {
        height: 350,
        type: 'line',
        toolbar: { show: false },
        zoom: { enabled: false },
        fontFamily: 'ui-sans-serif, system-ui, sans-serif',
      },
      yaxis: { labels: { formatter: val => formatSeconds(val) } },
      tooltip: {
        shared: true,
        x: { format: viewMode === 'timeline' ? 'dd MMM yyyy' : 'dd MMM' },
        y: series.map(() => ({
          formatter: (val, { seriesIndex, dataPointIndex, w }) => {
            if (val == null) return null;
            const item = w.config.series[seriesIndex]?.data[dataPointIndex];
            return item?.run_id
              ? `${formatSeconds(val)} (Event #${item.run_id})`
              : formatSeconds(val);
          },
        })),
      },
    };

    if (!chart) {
      chart = new ApexCharts(
        document.querySelector('#performance-chart'),
        options,
      );
      chart.render();
    } else {
      chart.updateOptions(options);
    }

    // Table Logic
    let tableRows = filteredRows;
    if (viewMode === 'timeline' && selectedYear !== 'All') {
      tableRows = filteredRows.filter(r => r.date.startsWith(selectedYear));
    } else if (viewMode === 'compare') {
      tableRows = filteredRows.filter(r =>
        selectedYears.includes(r.date.substring(0, 4)),
      );
    }

    const byAge = tableRows.reduce((acc, curr) => {
      if (!acc[curr.age_category])
        acc[curr.age_category] = {
          fastest: Infinity,
          slowest: 0,
          sumSeconds: 0,
          finishers: 0,
        };
      acc[curr.age_category].fastest = Math.min(
        acc[curr.age_category].fastest,
        curr.fastest,
      );
      acc[curr.age_category].slowest = Math.max(
        acc[curr.age_category].slowest,
        curr.slowest,
      );
      acc[curr.age_category].sumSeconds += curr.average * curr.finishers;
      acc[curr.age_category].finishers += curr.finishers;
      return acc;
    }, {});

    let tableData = Object.keys(byAge).map(cat => ({
      category: cat,
      fastest: byAge[cat].fastest,
      average: byAge[cat].sumSeconds / byAge[cat].finishers,
      slowest: byAge[cat].slowest,
    }));

    // Sort the data
    tableData.sort((a, b) => {
      let valA = a[currentSort.col];
      let valB = b[currentSort.col];

      if (typeof valA === 'string') {
        return currentSort.dir === 'asc'
          ? valA.localeCompare(valB)
          : valB.localeCompare(valA);
      }
      return currentSort.dir === 'asc' ? valA - valB : valB - valA;
    });

    tableBody.innerHTML = tableData
      .map(
        row => `
        <tr>
          <td class="font-medium">${row.category}</td>
          <td class="text-right">${formatSeconds(row.fastest)}</td>
          <td class="text-right">${formatSeconds(row.average)}</td>
          <td class="text-right text-muted">${formatSeconds(row.slowest)}</td>
        </tr>
      `,
      )
      .join('');
  }

  function updateSortIcons() {
    document.querySelectorAll('.data-table th.sortable').forEach(th => {
      const icon = th.querySelector('.sort-icon');
      if (th.dataset.col === currentSort.col) {
        icon.textContent = currentSort.dir === 'asc' ? '↑' : '↓';
      } else {
        icon.textContent = '↕';
      }
    });
  }

  [genderFilter, ageFilter, yearFilter].forEach(f =>
    f.addEventListener('change', updateView),
  );
  multiYearContainer.addEventListener('change', e => {
    if (e.target.classList.contains('perf-year-checkbox')) {
      const checked = multiYearContainer.querySelectorAll(
        '.perf-year-checkbox:checked',
      );
      if (checked.length > 2) {
        e.target.checked = false;
      } else {
        updateView();
      }
    }
  });
  updateView();
</script>

<style>
  .attendance-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .controls-bar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: white;
    border-radius: 0.75rem;
    border: 1px solid #f3f4f6;
    padding: 1rem;
    align-items: flex-start;
  }
  .mode-selector,
  .filter-row {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    width: fit-content;
  }
  .radio-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
  }
  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .filter-group label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }
  .filter-group select {
    padding: 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    font-weight: 600;
    background-color: #f9fafb;
  }
  .checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    background: #f9fafb;
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
  }
  .hidden {
    display: none;
  }
  .chart-card {
    background: white;
    border: 1px solid #f3f4f6;
    padding: 1.5rem;
    border-radius: 1.5rem;
  }
  .table-card {
    background: white;
    border: 1px solid #e5e7eb;
    overflow-x: auto;
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .data-table :global(th),
  .data-table :global(td) {
    padding: 1rem 1.25rem;
    border: 1px solid #e5e7eb;
  }
  .data-table :global(th) {
    text-align: left;
    background: #f9fafb;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
  }
  .data-table :global(tr:nth-child(even)) {
    background-color: #fafafa;
  }
  .data-table :global(.text-right) {
    text-align: right;
  }
  .data-table :global(.font-medium) {
    font-weight: 500;
  }
  .data-table :global(.text-muted) {
    color: var(--text-muted);
  }
</style>
