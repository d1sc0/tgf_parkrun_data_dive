---
import { runQuery } from '../lib/bigquery';

interface Props {
  isPreview?: boolean;
}

const { isPreview = false } = Astro.props;

const projectId = import.meta.env.GCP_PROJECT_ID;
const datasetId = import.meta.env.BIGQUERY_DATASET_ID || 'parkrun_data';

const user = Astro.locals.user;

// 1. Fetch home run stats from BigQuery
const bqQuery = `
  SELECT 
    home_run_name,
    COUNT(DISTINCT athlete_id) as athlete_count
  FROM \`${projectId}.${datasetId}.results\`
  WHERE home_run_name IS NOT NULL AND home_run_name != ''
    AND is_unknown_athlete = false
  GROUP BY home_run_name
  ORDER BY athlete_count DESC
`;

let mapData = [];
try {
  // Fetch BigQuery stats and Parkrun event coordinates in parallel
  const [homeRunStats, eventsResponse] = await Promise.all([
    runQuery(bqQuery),
    fetch('https://images.parkrun.com/events.json'),
  ]);

  const eventsData = await eventsResponse.json();
  const allEvents = eventsData.events.features;

  // Match BigQuery home run names to coordinates in events.json
  mapData = (homeRunStats || [])
    .map(stat => {
      const eventMatch = allEvents.find(
        e =>
          e.properties.eventname.toLowerCase() ===
            stat.home_run_name.toLowerCase() ||
          e.properties.EventLongName.toLowerCase() ===
            stat.home_run_name.toLowerCase(),
      );

      if (eventMatch) {
        return {
          name: stat.home_run_name,
          count: stat.athlete_count,
          lat: eventMatch.geometry.coordinates[1],
          lng: eventMatch.geometry.coordinates[0],
        };
      }
      return null;
    })
    .filter(Boolean);
} catch (error) {
  console.error('Failed to fetch map data:', error);
}
---

<div class="map-card">
  {
    !isPreview && (
      <div class="card-header">
        <h3 class="card-title">Visitors Map</h3>
        <p class="card-subtitle">
          Geographic spread of athletes based on their registered home run.
        </p>
      </div>
    )
  }

  <div class="map-wrapper">
    <div
      id="home-run-map"
      class:list={['map-container', { 'is-preview': isPreview || !user }]}
    >
    </div>
    {isPreview && <div class="map-overlay-title">TGF Visitor Map</div>}
  </div>
</div>

<!-- Leaflet assets -->
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>
<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""></script>

<script define:vars={{ mapData, isPreview, isLoggedIn: !!user }}>
  function initMap() {
    // Safety check for Leaflet availability
    if (typeof L === 'undefined') {
      setTimeout(initMap, 100);
      return;
    }

    // Default view centered on the UK
    const mapOptions =
      isPreview || !isLoggedIn
        ? {
            dragging: false,
            zoomControl: false,
            scrollWheelZoom: false,
            doubleClickZoom: false,
            touchZoom: false,
            attributionControl: false,
          }
        : {};

    const map = L.map('home-run-map', mapOptions).setView([54.5, -3], 6);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    }).addTo(map);

    const markers = [];

    mapData.forEach(point => {
      const marker = L.circleMarker([point.lat, point.lng], {
        radius: 6,
        fillColor: '#2563eb',
        color: '#ffffff',
        weight: 1,
        opacity: 1,
        fillOpacity: 0.6,
      });

      if (!isPreview && isLoggedIn) {
        marker.bindPopup(
          `<strong>${point.name}</strong><br/>Athletes: ${point.count}`,
        );
      }

      marker.addTo(map);

      markers.push([point.lat, point.lng]);
    });

    // Auto-zoom to fit all found markers
    if (markers.length > 0) {
      map.fitBounds(L.latLngBounds(markers), { padding: [50, 50] });
    }
  }

  initMap();
  // Support for Astro View Transitions if enabled later
  document.addEventListener('astro:page-load', initMap);
</script>

<style>
  .map-card {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    border: 1px solid #e5e7eb;
  }

  .card-header {
    padding: 1.5rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--text-main);
    margin: 0;
  }

  .card-subtitle {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0.25rem 0 0 0;
  }

  .map-wrapper {
    position: relative;
  }

  .map-container {
    height: 600px;
    width: 100%;
    z-index: 1;
    background: #f8fafc;
  }

  .map-container.is-preview {
    height: 300px;
    pointer-events: none;
  }

  .map-overlay-title {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 20;
    background: rgba(255, 255, 255, 0.95);
    padding: 0.5rem 0.875rem;
    border-radius: 0.75rem;
    font-weight: 800;
    font-size: 0.75rem;
    color: var(--text-main);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    pointer-events: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid #e5e7eb;
  }

  /* Fix for leaflet popup styles to match dashboard theme */
  :global(.leaflet-popup-content-wrapper) {
    border-radius: 0.75rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  :global(.leaflet-popup-content) {
    font-family: inherit;
  }
</style>
