    background: #eff6ff;
    color: #1e40af;
  } /* 60%+ */

  .first-finishers-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .time-stats-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .time-stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .time-stat-row:last-child {
    border-bottom: none;
  }

  .ts-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .ts-result {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ts-value {
    font-weight: 800;
    color: var(--text-main);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .ff-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .ff-meta {
    display: flex;
    flex-direction: column;
  }
  .ff-gender {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .ff-name {
    font-weight: 700;
    color: var(--text-main);
  }

  .ff-stats {
    display: flex;
    flex-direction: column;
    text-align: right;
  }
  .ff-time {
    font-weight: 800;
    color: #059669;
  }
  .ff-grading {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .empty-state {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .visitors-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .v-tag {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #f9fafb;
    padding: 0.375rem 0.75rem;
    border-radius: 2rem;
    border: 1px solid #f3f4f6;
  }

  .v-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-main);
  }

  .v-count {
    font-size: 0.7rem;
    font-weight: 800;
    background: white;
    color: #2563eb;
    padding: 0.125rem 0.375rem;
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
  }

  .report-pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e5e7eb;
  }

  .pag-link {
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 700;
    color: #2563eb;
    padding: 0.5rem 1rem;
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 0.75rem;
