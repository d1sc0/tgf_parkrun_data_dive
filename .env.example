# Parkrun API client credentials (OAuth client ID/secret for the Parkrun iOS app)
PARKRUN_CLIENT_ID=your-parkrun-client-id
PARKRUN_CLIENT_SECRET=your-parkrun-client-secret

# Google Cloud configuration
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CREDENTIALS_PATH=./service-account-key.json

# BigQuery configuration
BIGQUERY_DATASET_ID=parkrun_data
BIGQUERY_RESULTS_TABLE=results
BIGQUERY_VOLUNTEERS_TABLE=volunteers
BIGQUERY_JUNIOR_RESULTS_TABLE=junior_results
BIGQUERY_JUNIOR_VOLUNTEERS_TABLE=junior_volunteers
BIGQUERY_WEATHER_TABLE=event_weather

# Weather sync configuration (RunReport weather cache)
WEATHER_LATITUDE=50.7123
WEATHER_LONGITUDE=-2.4651
WEATHER_HOUR_UTC=9

# Runtime flags
RUN_JUNIOR=false

# API fetch optimization
# FETCH_LATEST_ONLY=true will only fetch rows for the newest event date.
FETCH_LATEST_ONLY=true
# TARGET_EVENT_NUMBER filters to a specific RunId for this venue (e.g. 232).
TARGET_EVENT_NUMBER=
# START_EVENT_NUMBER starts full run-scoped history at this RunId (e.g. 232).
# Applies when SCRAPE_ALL_EVENTS=true, FETCH_LATEST_ONLY=false, and TARGET_EVENT_NUMBER is empty.
START_EVENT_NUMBER=

# Scrape mode controls
# true = ignore incremental check and pull full history (still constrained by fetch flags)
SCRAPE_ALL_EVENTS=false
# Optional: limit write scope to the most recent N event dates after filtering
SCRAPE_MAX_EVENTS=1
# Optional: delay between run-scoped requests in full-history mode
RUN_FETCH_DELAY_MS=750

# Parkrun configuration
PARKRUN_EVENT_ID=eventID
PARKRUN_PASSWORD = password
PARKRUN_USERNAME = username
JUNIOR_EVENT_ID = eventID
JUNIOR_USERNAME = username
JUNIOR_PASSWORD = password
