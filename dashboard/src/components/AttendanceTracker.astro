---
import { runQuery } from '../lib/bigquery';

/**
 * We fetch data grouped by date, gender, and age category.
 * Parkrun age categories typically look like 'VM40-44' (Vet Male), 'SW25-29' (Senior Woman), etc.
 */
const query = `
  SELECT
    event_date,
    CASE
      WHEN age_category LIKE 'W%' OR age_category LIKE 'JW%' OR age_category LIKE 'SW%' OR age_category LIKE 'VW%' THEN 'Female'
      WHEN age_category LIKE 'M%' OR age_category LIKE 'JM%' OR age_category LIKE 'SM%' OR age_category LIKE 'VM%' THEN 'Male'
      ELSE 'Unknown'
    END as gender,
    CASE
      WHEN age_category LIKE 'J%' THEN 'Junior'
      WHEN age_category LIKE 'S%' THEN 'Senior'
      WHEN age_category LIKE 'V%' THEN 'Veteran'
      ELSE 'Other'
    END as age_group,
    age_category,
    run_id,
    count(*) as finishers
  FROM \`${import.meta.env.GCP_PROJECT_ID}.parkrun_data.results\`
  GROUP BY event_date, run_id, gender, age_group, age_category
  ORDER BY event_date ASC
`;

let rows = [];
try {
  rows = await runQuery(query);
} catch (e) {
  console.error('BigQuery Error in AttendanceTracker:', e);
}

// Prepare data for the client
const data = rows.map(r => ({
  date: r.event_date.value || r.event_date,
  run_id: r.run_id,
  gender: r.gender,
  age_group: r.age_group,
  age_category: r.age_category,
  finishers: Number(r.finishers),
}));

// Extract unique years for the multi-select picker
const allYears = [...new Set(data.map(d => d.date.substring(0, 4)))]
  .filter(Boolean)
  .sort((a, b) => b.localeCompare(a));
---

<div class="attendance-wrapper">
  <div class="controls-bar">
    <!-- Mode Selector -->
    <div class="mode-selector">
      <label class="radio-label">
        <input type="radio" name="view-mode" value="timeline" checked />
        <span>Timeline</span>
      </label>
      <label class="radio-label">
        <input type="radio" name="view-mode" value="compare" />
        <span>Compare Years</span>
      </label>
    </div>

    <div class="filter-row">
      <div id="year-dropdown-container" class="filter-group">
        <label for="year-filter">Year</label>
        <select id="year-filter">
          <option value="All">All Years</option>
          {allYears.map(year => <option value={year}>{year}</option>)}
        </select>
      </div>

      <div class="filter-group">
        <label for="gender-filter">Gender</label>
        <select id="gender-filter">
          <option value="All">All Genders</option>
          <option value="Male">Male</option>
          <option value="Female">Female</option>
          <option value="Unknown">Unknown</option>
        </select>
      </div>
      <div class="filter-group">
        <label for="age-filter">Age Category</label>
        <select id="age-filter">
          <option value="All">All Categories</option>
          <option value="Junior">Junior</option>
          <option value="Senior">Senior</option>
          <option value="Veteran">Veteran</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>

    <!-- Comparison Selection (visible when 'Compare' mode active) -->
    <div id="multi-year-container" class="hidden">
      <div class="filter-group">
        <label>Select Years to Overlay</label>
        <div class="checkbox-group">
          {
            allYears.map((year, i) => (
              <label class="checkbox-item">
                <input
                  type="checkbox"
                  value={year}
                  checked={i < 2}
                  class="year-checkbox"
                />
                {year}
              </label>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Chart Container -->
  <div class="chart-card">
    <div id="attendance-chart"></div>
  </div>

  <!-- Data Table -->
  <div class="table-card">
    <table class="data-table">
      <thead>
        <tr>
          <th>Age Category</th>
          <th class="text-right">Finishers</th>
          <th class="text-right">% of Total</th>
        </tr>
      </thead>
      <tbody id="attendance-table-body">
        <!-- Populated via Script -->
      </tbody>
      <tfoot id="attendance-table-footer">
        <!-- Totals via Script -->
      </tfoot>
    </table>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<script define:vars={{ rawData: data }}>
  let chart;
  const genderFilter = document.getElementById('gender-filter');
  const ageFilter = document.getElementById('age-filter');
  const yearFilter = document.getElementById('year-filter');
  const multiYearContainer = document.getElementById('multi-year-container');
  const tableBody = document.getElementById('attendance-table-body');
  const tableFooter = document.getElementById('attendance-table-footer');
  const modeRadios = document.querySelectorAll('input[name="view-mode"]');
  const yearDropdownContainer = document.getElementById(
    'year-dropdown-container',
  );

  // Handle Mode Toggle
  modeRadios.forEach(radio => {
    radio.addEventListener('change', () => {
      const isCompare = radio.value === 'compare';
      multiYearContainer.classList.toggle('hidden', !isCompare);
      yearDropdownContainer.classList.toggle('hidden', isCompare);
      document
        .querySelector('.table-card')
        ?.classList.toggle('hidden', isCompare);
      updateView();
    });
  });

  function updateView() {
    const viewMode = document.querySelector(
      'input[name="view-mode"]:checked',
    ).value;
    const selectedGender = genderFilter.value;
    const selectedAge = ageFilter.value;
    const selectedYear = yearFilter.value;
    const selectedYears =
      viewMode === 'compare'
        ? Array.from(document.querySelectorAll('.year-checkbox:checked')).map(
            cb => cb.value,
          )
        : [];

    // 1. Base Filter (Gender and Age Group)
    let filteredRows = rawData.filter(curr => {
      const genderMatch =
        selectedGender === 'All' || curr.gender === selectedGender;
      const ageMatch = selectedAge === 'All' || curr.age_group === selectedAge;
      return genderMatch && ageMatch;
    });

    // 2. Handle Chart Logic
    let series = [];
    let chartOptions = {};

    if (viewMode === 'timeline') {
      // Filter by the single year dropdown if not 'All'
      const timelineRows =
        selectedYear === 'All'
          ? filteredRows
          : filteredRows.filter(r => r.date.startsWith(selectedYear));

      const byDate = timelineRows.reduce((acc, curr) => {
        if (!acc[curr.date])
          acc[curr.date] = { finishers: 0, run_id: curr.run_id };
        acc[curr.date].finishers += curr.finishers;
        return acc;
      }, {});

      const sortedDates = Object.keys(byDate).sort();
      const seriesData = sortedDates.map(date => ({
        x: new Date(date).getTime(),
        y: byDate[date].finishers,
        run_id: byDate[date].run_id,
      }));

      const trendData = sortedDates.map((date, i) => {
        const slice = sortedDates.slice(Math.max(0, i - 15), i + 1);
        const avg =
          slice.reduce((sum, d) => sum + byDate[d].finishers, 0) / slice.length;
        return { x: new Date(date).getTime(), y: Math.round(avg) };
      });

      series = [
        { name: 'Finishers', type: 'line', data: seriesData },
        {
          name: 'Trend',
          type: 'line',
          data: trendData,
          tooltip: { enabled: false },
        },
      ];

      chartOptions = {
        colors: ['#2563eb', '#ef4444'],
        stroke: { width: [3, 3], curve: ['straight', 'smooth'] },
        xaxis: {
          type: 'datetime',
          labels: { format: selectedYear === 'All' ? 'MMM yyyy' : 'dd MMM' },
        },
        tooltip: { x: { format: 'dd MMM yyyy' } },
      };
    } else {
      // Comparison Logic (Overlay Years)
      const colors = [
        '#2563eb',
        '#ef4444',
        '#16a34a',
        '#facc15',
        '#a855f7',
        '#fb923c',
      ];

      selectedYears.forEach((year, idx) => {
        const yearRows = filteredRows.filter(r => r.date.startsWith(year));
        const byDay = yearRows.reduce((acc, curr) => {
          const md = curr.date.substring(5); // MM-DD
          if (!acc[md]) acc[md] = { finishers: 0, run_id: curr.run_id };
          acc[md].finishers += curr.finishers;
          return acc;
        }, {});

        const seriesData = Object.keys(byDay)
          .sort()
          .map(md => {
            const [m, d] = md.split('-');
            return {
              x: new Date(2024, parseInt(m) - 1, parseInt(d)).getTime(),
              y: byDay[md].finishers,
              run_id: byDay[md].run_id,
            };
          });

        series.push({
          name: year,
          type: 'line',
          data: seriesData,
          color: colors[idx % colors.length],
        });
      });

      chartOptions = {
        stroke: { width: 3, curve: 'smooth' },
        xaxis: { type: 'datetime', labels: { format: 'MMM' } },
        tooltip: { x: { format: 'dd MMM' } },
      };
    }

    const options = {
      series,
      ...chartOptions,
      chart: {
        height: 350,
        type: 'line',
        toolbar: { show: false },
        zoom: { enabled: false },
        fontFamily: 'ui-sans-serif, system-ui, sans-serif',
      },
      yaxis: { min: 0 },
      tooltip: {
        ...chartOptions.tooltip,
        shared: true,
        y:
          viewMode === 'timeline'
            ? [
                {
                  formatter: (val, { seriesIndex, dataPointIndex, w }) => {
                    if (val == null) return null;
                    const item =
                      w.config.series[seriesIndex].data[dataPointIndex];
                    return item?.run_id
                      ? `${val.toLocaleString()} (Event #${item.run_id})`
                      : val.toLocaleString();
                  },
                },
                { formatter: () => null }, // Hide trend line value
              ]
            : series.map(() => ({
                formatter: (val, { seriesIndex, dataPointIndex, w }) => {
                  if (val == null) return null;
                  const item =
                    w.config.series[seriesIndex].data[dataPointIndex];
                  return item?.run_id
                    ? `${val.toLocaleString()} (Event #${item.run_id})`
                    : val.toLocaleString();
                },
              })),
      },
    };

    if (!chart) {
      chart = new ApexCharts(
        document.querySelector('#attendance-chart'),
        options,
      );
      chart.render();
    } else {
      chart.updateOptions(options);
    }

    // 3. Update Table logic
    let tableRows = filteredRows;
    if (viewMode === 'timeline' && selectedYear !== 'All') {
      tableRows = filteredRows.filter(r => r.date.startsWith(selectedYear));
    } else if (viewMode === 'compare') {
      tableRows = filteredRows.filter(r =>
        selectedYears.includes(r.date.substring(0, 4)),
      );
    }

    const byAge = tableRows.reduce((acc, curr) => {
      acc[curr.age_category] = (acc[curr.age_category] || 0) + curr.finishers;
      return acc;
    }, {});

    const totalFinishers = Object.values(byAge).reduce((a, b) => a + b, 0);
    const sortedGroups = Object.keys(byAge).sort();

    tableBody.innerHTML = sortedGroups
      .map(category => {
        const count = byAge[category];
        const percent =
          totalFinishers > 0 ? ((count / totalFinishers) * 100).toFixed(2) : 0;
        return `
      <tr>
        <td class="font-medium">${category}</td>
        <td class="text-right">${count.toLocaleString()}</td>
        <td class="text-right text-muted">${percent}%</td>
      </tr>
      `;
      })
      .join('');

    tableFooter.innerHTML = `
      <tr class="footer-row">
        <td>Total</td>
        <td class="text-right">${totalFinishers.toLocaleString()}</td>
        <td class="text-right">100%</td>
      </tr>
    `;
  }

  genderFilter.addEventListener('change', updateView);
  ageFilter.addEventListener('change', updateView);
  yearFilter.addEventListener('change', updateView);

  multiYearContainer.addEventListener('change', e => {
    if (e.target.classList.contains('year-checkbox')) updateView();
  });

  // Initial render
  updateView();
</script>

<style>
  .attendance-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .controls-bar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: white;
    border-radius: 0.75rem;
    border: 1px solid #f3f4f6;
    padding-top: 1rem;
    padding-bottom: 1rem;
    align-items: flex-start;
  }

  .mode-selector {
    display: flex;
    gap: 1.25rem;
    padding: 0.75rem 1.25rem;
    width: fit-content;
  }

  .radio-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
  }

  .filter-row {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding: 0.75rem 1.25rem;
    width: fit-content;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .filter-group label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .filter-group select {
    padding: 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    font-weight: 600;
    background-color: #f9fafb;
  }

  #multi-year-container {
    background: white;
    padding: 0.75rem 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid #f3f4f6;
    width: fit-content;
  }

  .filter-group select[multiple] {
    height: auto;
    min-height: 40px;
    min-width: 120px;
  }
  .checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    background: #f9fafb;
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
  }

  .hidden {
    display: none;
  }

  .chart-card,
  .table-card {
    background: white;
    border: 1px solid #f3f4f6;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  }

  .chart-card {
    padding: 1.5rem;
    border-radius: 1.5rem;
  }

  .table-card {
    padding: 0;
    border-radius: 0; /* Removed rounded corners */
    border: 1px solid #e5e7eb;
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  /* Use :global to target elements injected via innerHTML */
  .data-table :global(th),
  .data-table :global(td) {
    padding: 1rem 1.25rem;
    border: 1px solid #e5e7eb;
  }

  .data-table :global(th) {
    text-align: left;
    background: #f9fafb;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .data-table :global(tr:nth-child(even)) {
    background-color: #fafafa;
  }

  .data-table :global(tr:hover) {
    background-color: #f3f4f6;
  }

  .data-table :global(.footer-row td) {
    background-color: #f9fafb !important;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-top: 2px solid #d1d5db;
  }

  .data-table :global(.text-right) {
    text-align: right;
  }
  .data-table :global(.font-bold) {
    font-weight: 700;
  }
  .data-table :global(.font-medium) {
    font-weight: 500;
  }
  .data-table :global(.text-muted) {
    color: var(--text-muted);
  }
</style>
