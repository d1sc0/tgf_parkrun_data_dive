---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

// In Astro SSR, user state is typically passed via Astro.locals from middleware
const user = Astro.locals.user;
---

<header class="header">
  <div class="header-content">
    <div class="title-group">
      <a href="/" class="title-link">
        <h1 class="title">TGF parkrun</h1>
      </a>
      {title && <p class="page-title">{title}</p>}
    </div>

    <nav class="nav">
      <button id="menu-toggle" class="menu-button" aria-label="Toggle Menu">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line class="line top" x1="3" y1="6" x2="21" y2="6"></line>
          <line class="line middle" x1="3" y1="12" x2="21" y2="12"></line>
          <line class="line bottom" x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <ul id="nav-links" class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/attendance">Attendance</a></li>
        <li><a href="/performance">Performance</a></li>
        <li><a href="/volunteers">Volunteers</a></li>
        {
          user && (
            <li class="nav-divider" role="separator" />
            <li class="nav-section-label">Protected</li>
            <li class="protected-link">
              <a href="/run-report">Run Reports</a>
            </li>
            <li class="protected-link">
              <a href="/top-lists">Top 20 Lists</a>
            </li>
            <li class="protected-link">
              <a href="/records">Course Records</a>
            </li>
            <li class="protected-link">
              <a href="/visitors-map">Visitors Map</a>
            </li>
            <li class="protected-link">
              <a href="/volunteer-milestones">Volunteer Milestones</a>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const links = document.getElementById('nav-links');

  toggle?.addEventListener('click', () => {
    links?.classList.toggle('show');
    toggle?.classList.toggle('menu-open'); // Toggle class on the button itself
  });

  // Close menu when clicking outside
  document.addEventListener('click', event => {
    if (
      !toggle?.contains(event.target as Node) &&
      !links?.contains(event.target as Node)
    ) {
      links?.classList.remove('show');
      toggle?.classList.remove('menu-open'); // Ensure button state is reset
    }
  });
</script>

<style>
  .header {
    margin-bottom: 2.5rem;
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
  }

  /** 
   * The nav is absolutely positioned to ensure the hamburger 
   * remains at the very top of the header area, regardless of 
   * how long the TGF title or page description wraps.
   */
  .nav {
    /* Position the nav (containing the hamburger) absolutely */
    position: absolute;
    top: 0;
    right: 0;
  }

  .title {
    font-size: 2.25rem;
    font-weight: 900;
    letter-spacing: -0.025em;
    margin: 0;
    line-height: 1;
  }

  .title-link {
    text-decoration: none;
    color: inherit;
  }

  .menu-button {
    background: white;
    border: 1px solid #e5e7eb;
    padding: 0.5rem;
    border-radius: 0.75rem;
    cursor: pointer;
    color: var(--text-main);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }

  .menu-button .line {
    transition:
      transform 0.3s ease-in-out,
      opacity 0.3s ease-in-out;
    transform-origin: 50% 50%;
    transform-box: fill-box;
  }

  .menu-button.menu-open .line.top {
    transform: translateY(6px) rotate(45deg);
  }

  .menu-button.menu-open .line.middle {
    opacity: 0;
  }

  .menu-button.menu-open .line.bottom {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Desktop styles for navigation */
  @media (min-width: 768px) {
    .header-content {
      align-items: center; /* Align title and nav vertically */
    }
  }

  .nav-links {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    padding: 0.5rem;
    list-style: none;
    min-width: 240px;
    z-index: 100;
    margin-top: 0.5rem;
  }

  .nav-links.show {
    display: block;
  }

  .nav-links li a {
    display: block;
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: var(--text-main);
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 0.5rem;
    white-space: nowrap;
  }

  .nav-links li a:hover {
    background: #f3f4f6;
  }

  .nav-divider {
    height: 1px;
    background-color: #f3f4f6;
    margin: 0.5rem 0.75rem;
  }

  .nav-section-label {
    padding: 0.5rem 1rem 0.25rem 1rem;
    font-size: 0.65rem;
    font-weight: 800;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: default;
  }

  .protected-link a {
    padding-left: 1.75rem !important;
  }

  .description {
    color: var(--text-muted);
    margin-top: 0.5rem;
  }
</style>
