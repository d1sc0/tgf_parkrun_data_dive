---
import { runQuery } from '../lib/bigquery';

/**
 * Volunteer Query:
 * Retrieves event dates, run IDs, and task names.
 * Athlete IDs are used only for calculating unique counts on the server.
 * Aggregates volunteer records and joins with finisher counts per run
 * to calculate the volunteer-to-runner ratio.
 */
const query = `
  WITH event_finishers AS (
    SELECT run_id, COUNT(*) as total_finishers
    FROM \`${import.meta.env.GCP_PROJECT_ID}.parkrun_data.results\`
    GROUP BY run_id
  )
  SELECT
    v.event_date,
    v.run_id,
    v.task_name,
    v.athlete_id,
    EXTRACT(YEAR FROM v.event_date) as year,
    f.total_finishers
  FROM \`${import.meta.env.GCP_PROJECT_ID}.parkrun_data.volunteers\` v
  LEFT JOIN event_finishers f ON v.run_id = f.run_id
  ORDER BY v.event_date ASC
`;

let rows = [];
try {
  rows = await runQuery(query);
} catch (e) {
  console.error('BigQuery Error in VolunteerTracker:', e);
}

// Prepare data for the client (No Names/PII)
const data = rows.map(r => ({
  date: r.event_date.value || r.event_date,
  run_id: r.run_id,
  role: r.task_name || 'Unknown',
  year: String(r.year),
  finishers: Number(r.total_finishers || 0),
  athlete_id: r.athlete_id,
}));

const allYears = [...new Set(data.map(d => d.year))]
  .filter(Boolean)
  .sort((a, b) => b.localeCompare(a));
---

<div class="volunteer-wrapper">
  <div class="controls-bar">
    <div class="mode-selector">
      <label class="radio-label">
        <input type="radio" name="vol-view-mode" value="timeline" checked />
        <span>Timeline</span>
      </label>
      <label class="radio-label">
        <input type="radio" name="vol-view-mode" value="compare" />
        <span>Compare Years</span>
      </label>
    </div>

    <div class="filter-row">
      <div id="vol-year-dropdown-container" class="filter-group">
        <label for="vol-year-filter">Year</label>
        <select id="vol-year-filter">
          <option value="All">All Years</option>
          {allYears.map(year => <option value={year}>{year}</option>)}
        </select>
      </div>
    </div>

    <div id="vol-multi-year-container" class="hidden">
      <div class="filter-group">
        <label>Select 2 Years to Overlay</label>
        <div class="checkbox-group">
          {
            allYears.map((year, i) => (
              <label class="checkbox-item">
                <input
                  type="checkbox"
                  value={year}
                  checked={i < 2}
                  class="vol-year-checkbox"
                />
                {year}
              </label>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="chart-card">
    <h3 class="card-title">Weekly Volunteer Support</h3>
    <div id="volunteer-timeline-chart"></div>
  </div>

  <!-- Summary Stat Cards -->
  <div class="volunteer-stats-grid">
    <div class="v-stat-card">
      <p class="v-stat-label">Total Credits Awarded</p>
      <p class="v-stat-value" id="stat-total-credits">0</p>
    </div>
    <div class="v-stat-card">
      <p class="v-stat-label">Avg Helpers / Week</p>
      <p class="v-stat-value" id="stat-avg-helpers">0</p>
    </div>
    <div class="v-stat-card">
      <p class="v-stat-label">Avg Vol : Runner Ratio</p>
      <p class="v-stat-value" id="stat-vol-ratio">0</p>
    </div>
    <div class="v-stat-card">
      <p class="v-stat-label">Unique Volunteers</p>
      <p class="v-stat-value" id="stat-unique-vols">0</p>
    </div>
  </div>

  <div class="table-card">
    <div class="table-header-box">
      <h3 class="card-title">Breakdown of Credits Awarded</h3>
    </div>
    <table class="data-table">
      <thead>
        <tr>
          <th class="sortable" data-col="role"
            >Role <span class="sort-icon">↕</span></th
          >
          <th class="text-right sortable" data-col="count"
            >Credits <span class="sort-icon">↕</span></th
          >
        </tr>
      </thead>
      <tbody id="vol-table-body"></tbody>
      <tfoot id="vol-table-footer"></tfoot>
    </table>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<script define:vars={{ rawData: data }}>
  let timelineChart;
  const wrapper = document.querySelector('.volunteer-wrapper');
  const yearFilter = wrapper.querySelector('#vol-year-filter');
  const multiYearContainer = wrapper.querySelector('#vol-multi-year-container');
  const yearDropdownContainer = wrapper.querySelector(
    '#vol-year-dropdown-container',
  );
  const modeRadios = wrapper.querySelectorAll('input[name="vol-view-mode"]');
  const tableBody = wrapper.querySelector('#vol-table-body');
  const tableFooter = wrapper.querySelector('#vol-table-footer');
  const statTotalCredits = wrapper.querySelector('#stat-total-credits');
  const statAvgHelpers = wrapper.querySelector('#stat-avg-helpers');
  const statVolRatio = wrapper.querySelector('#stat-vol-ratio');
  const statUniqueVols = wrapper.querySelector('#stat-unique-vols');

  let currentSort = { col: 'count', dir: 'desc' };

  wrapper.querySelectorAll('.data-table th.sortable').forEach(th => {
    th.addEventListener('click', () => handleSort(th.dataset.col));
  });

  modeRadios.forEach(radio => {
    radio.addEventListener('change', () => {
      const isCompare = radio.value === 'compare';
      multiYearContainer.classList.toggle('hidden', !isCompare);
      yearDropdownContainer.classList.toggle('hidden', isCompare);
      wrapper
        .querySelector('.volunteer-stats-grid')
        ?.classList.toggle('hidden', isCompare);
      wrapper
        .querySelector('.table-card')
        ?.classList.toggle('hidden', isCompare);
      updateView();
    });
  });

  function handleSort(col) {
    if (currentSort.col === col) {
      currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
    } else {
      currentSort.col = col;
      currentSort.dir = 'asc';
    }
    updateSortIcons();
    updateView();
  }

  function updateView() {
    const viewMode = wrapper.querySelector(
      'input[name="vol-view-mode"]:checked',
    ).value;
    const selectedYear = yearFilter.value;
    const selectedYears =
      viewMode === 'compare'
        ? Array.from(
            wrapper.querySelectorAll('.vol-year-checkbox:checked'),
          ).map(cb => cb.value)
        : [];

    let filteredRows = rawData;

    // 1. Timeline Chart Logic
    let series = [];
    if (viewMode === 'timeline') {
      const timelineRows =
        selectedYear === 'All'
          ? rawData
          : rawData.filter(r => r.year === selectedYear);
      const byDate = timelineRows.reduce((acc, curr) => {
        acc[curr.date] = (acc[curr.date] || 0) + 1;
        return acc;
      }, {});

      const sortedDates = Object.keys(byDate).sort();
      series = [
        {
          name: 'Volunteers',
          data: sortedDates.map(date => ({
            x: new Date(date).getTime(),
            y: byDate[date],
          })),
        },
      ];
    } else {
      const colors = ['#a855f7', '#fb923c', '#2563eb'];
      selectedYears.forEach((year, idx) => {
        const yearRows = rawData.filter(r => r.year === year);
        const byDay = yearRows.reduce((acc, curr) => {
          const md = curr.date.substring(5);
          acc[md] = (acc[md] || 0) + 1;
          return acc;
        }, {});
        const seriesData = Object.keys(byDay)
          .sort()
          .map(md => {
            const [m, d] = md.split('-');
            return {
              x: new Date(2024, parseInt(m) - 1, parseInt(d)).getTime(),
              y: byDay[md],
            };
          });
        series.push({
          name: year,
          data: seriesData,
          color: colors[idx % colors.length],
        });
      });
    }

    const timelineOptions = {
      series,
      chart: {
        type: 'line',
        height: 300,
        toolbar: { show: false },
        fontFamily: 'ui-sans-serif, system-ui, sans-serif',
      },
      stroke: { width: 3, curve: 'smooth' },
      xaxis: { type: 'datetime' },
      colors: ['#a855f7'],
    };

    if (!timelineChart) {
      timelineChart = new ApexCharts(
        wrapper.querySelector('#volunteer-timeline-chart'),
        timelineOptions,
      );
      timelineChart.render();
    } else {
      timelineChart.updateOptions(timelineOptions);
    }

    // 2. Role Aggregation Logic
    const activeRows =
      viewMode === 'timeline'
        ? selectedYear === 'All'
          ? rawData
          : rawData.filter(r => r.year === selectedYear)
        : rawData.filter(r => selectedYears.includes(r.year));

    const roleCounts = activeRows.reduce((acc, curr) => {
      // Split combined roles (e.g., "Marshal, Run Director") and process each individually
      const rawRoles = (curr.role || 'Unknown').split(',');

      rawRoles.forEach(raw => {
        // Normalize role names: Trim whitespace and ensure consistent casing
        const normalizedRole = raw
          .trim()
          .split(' ')
          .map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())
          .join(' ');

        if (normalizedRole) {
          acc[normalizedRole] = (acc[normalizedRole] || 0) + 1;
        }
      });
      return acc;
    }, {});

    const totalCredits = Object.values(roleCounts).reduce((a, b) => a + b, 0);
    const uniqueDates = new Set(activeRows.map(r => r.date)).size;
    const avgHelpers =
      uniqueDates > 0 ? (activeRows.length / uniqueDates).toFixed(1) : 0;
    const totalUniqueVols = new Set(activeRows.map(r => r.athlete_id)).size;

    // Calculate Vol : Runner Ratio (based on headcount per event, not credits)
    const eventSummary = {}; // { run_id: { finishers: N, uniqueVols: Set } }
    activeRows.forEach(r => {
      if (!r.run_id) return;
      if (!eventSummary[r.run_id]) {
        eventSummary[r.run_id] = {
          finishers: r.finishers,
          uniqueVols: new Set(),
        };
      }
      eventSummary[r.run_id].uniqueVols.add(r.athlete_id);
    });

    const totalFinishers = Object.values(eventSummary).reduce(
      (a, b) => a + b.finishers,
      0,
    );
    const totalHeadcount = Object.values(eventSummary).reduce(
      (a, b) => a + b.uniqueVols.size,
      0,
    );
    const runnersPerVol =
      totalHeadcount > 0 ? (totalFinishers / totalHeadcount).toFixed(1) : 0;

    // Update Stat Cards
    statTotalCredits.textContent = totalCredits.toLocaleString();
    statAvgHelpers.textContent = avgHelpers;
    statVolRatio.textContent = `1:${runnersPerVol}`;
    statUniqueVols.textContent = totalUniqueVols.toLocaleString();

    // 3. Table Preparation
    let tableData = Object.entries(roleCounts).map(([role, count]) => ({
      role,
      count,
    }));

    tableData.sort((a, b) => {
      let valA = a[currentSort.col];
      let valB = b[currentSort.col];
      if (typeof valA === 'string') {
        return currentSort.dir === 'asc'
          ? valA.localeCompare(valB)
          : valB.localeCompare(valA);
      }
      return currentSort.dir === 'asc' ? valA - valB : valB - valA;
    });

    tableBody.innerHTML = tableData
      .map(
        row => `
      <tr>
        <td class="font-medium">${row.role}</td>
        <td class="text-right">${row.count.toLocaleString()}</td>
      </tr>
    `,
      )
      .join('');

    tableFooter.innerHTML = `
      <tr class="footer-row">
        <td class="font-bold">Total</td>
        <td class="text-right font-bold">${totalCredits.toLocaleString()}</td>
      </tr>
    `;
  }

  function updateSortIcons() {
    wrapper.querySelectorAll('.data-table th.sortable').forEach(th => {
      const icon = th.querySelector('.sort-icon');
      icon.textContent =
        th.dataset.col === currentSort.col
          ? currentSort.dir === 'asc'
            ? '↑'
            : '↓'
          : '↕';
    });
  }

  yearFilter.addEventListener('change', updateView);
  multiYearContainer.addEventListener('change', updateView);
  updateView();
</script>

<style>
  .volunteer-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .controls-bar {
    background: white;
    border-radius: 0.75rem;
    border: 1px solid #f3f4f6;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .mode-selector,
  .filter-row {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    width: 100%;
  }
  .radio-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
  }
  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .filter-group label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }
  .filter-group select {
    padding: 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    font-weight: 600;
    background-color: #f9fafb;
  }
  .checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    background: #f9fafb;
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
  }
  .chart-card {
    background: white;
    border: 1px solid #f3f4f6;
    padding: 1.5rem;
    border-radius: 1.5rem;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  }
  .card-title {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .table-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 1.5rem;
    overflow: hidden;
  }
  .table-header-box {
    padding: 1.5rem 1.5rem 0 1.5rem;
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .data-table :global(th),
  .data-table :global(td) {
    padding: 1rem 1.25rem;
    border: 1px solid #e5e7eb;
  }
  .data-table :global(th) {
    text-align: left;
    background: #f9fafb;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
    user-select: none;
  }
  .data-table :global(tr:nth-child(even)) {
    background-color: #fafafa;
  }
  .data-table :global(.footer-row td) {
    background-color: #f9fafb !important;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-top: 2px solid #d1d5db;
  }
  .text-right {
    text-align: right;
  }
  .text-muted {
    color: var(--text-muted);
  }
  .font-medium {
    font-weight: 500;
  }
  .font-bold {
    font-weight: 700;
  }
  .hidden {
    display: none !important;
  }

  .volunteer-stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .v-stat-card {
    background: white;
    padding: 1.25rem;
    border-radius: 1rem;
    border: 1px solid #f3f4f6;
    text-align: center;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  }

  .v-stat-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .v-stat-value {
    font-size: 1.5rem;
    font-weight: 900;
    color: #a855f7; /* Matching the volunteer purple theme */
    margin: 0;
  }

  @media (min-width: 1024px) {
    .volunteer-stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 640px) {
    .volunteer-stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
